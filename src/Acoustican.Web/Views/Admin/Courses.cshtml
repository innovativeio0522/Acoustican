@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Courses Management</h2>
    <button class="btn btn-primary" onclick="showCourseForm()">
        <i class="fas fa-plus"></i> Add Course
    </button>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Level</th>
                        <th>Price</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="coursesTable">
                    <tr>
                        <td colspan="6" class="text-center text-muted">Loading courses...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="courseModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="courseModalTitle">Add Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="courseForm">
                    <input type="hidden" id="courseId">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control" id="courseTitle" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thumbnail URL or Video URL</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="courseThumbnailUrl" placeholder="https://... or /uploads/...">
                            <input type="file" id="courseThumbnailFile" class="d-none" accept="image/*,video/*">
                            <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('courseThumbnailFile').click()">
                                <i class="fas fa-upload"></i> Upload
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="courseDescription" rows="3" required></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Level</label>
                            <select class="form-select" id="courseLevel">
                                <option value="Beginner">Beginner</option>
                                <option value="Intermediate">Intermediate</option>
                                <option value="Advanced">Advanced</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Price ($)</label>
                            <input type="number" class="form-control" id="coursePrice" step="0.01" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Original Price ($)</label>
                            <input type="number" class="form-control" id="courseOriginalPrice" step="0.01">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Duration (Minutes)</label>
                            <input type="number" class="form-control" id="courseDuration" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Lecture Count</label>
                            <input type="number" class="form-control" id="courseLectureCount">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Instructor Name</label>
                            <input type="text" class="form-control" id="courseInstructorName">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Rating</label>
                            <input type="number" class="form-control" id="courseRating" step="0.1" min="0" max="5">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Review Count</label>
                            <input type="number" class="form-control" id="courseReviewCount">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Student Count</label>
                            <input type="number" class="form-control" id="courseStudentCount">
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <div class="form-check mb-2 me-3">
                                <input class="form-check-input" type="checkbox" id="courseIsBestseller">
                                <label class="form-check-label">Bestseller</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="coursePublished">
                                <label class="form-check-label">Published</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">What You'll Learn (one per line)</label>
                        <textarea class="form-control" id="courseWhatYoullLearn" rows="3" placeholder="e.g. Learn open chords&#10;Master basic strumming"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Requirements (one per line)</label>
                        <textarea class="form-control" id="courseRequirements" rows="3" placeholder="e.g. Acoustic or electric guitar&#10;No prior experience needed"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveCourse()">Save Course</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadCourses();
        });
    </script>
}
