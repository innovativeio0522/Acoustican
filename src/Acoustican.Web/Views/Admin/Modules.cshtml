@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Modules";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Course Modules</h2>
    <div class="d-flex gap-2">
        <select class="form-select" id="moduleCourseFilter" style="width: 250px;" onchange="loadModules()">
            <option value="">Select a Course...</option>
        </select>
        <button class="btn btn-primary" onclick="showModuleForm()">
            <i class="fas fa-plus"></i> Add Module
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Title</th>
                        <th>Duration</th>
                        <th>Order</th>
                        <th>Published</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="modulesTable">
                    <tr>
                        <td colspan="6" class="text-center text-muted">Select a course to view modules...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="moduleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="moduleModalTitle">Add Module</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="moduleForm">
                    <input type="hidden" id="moduleId">
                    <div class="mb-3">
                        <label class="form-label">Course</label>
                        <select class="form-select" id="moduleCourseId" required></select>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Module Number</label>
                            <input type="number" class="form-control" id="moduleNumber" required>
                        </div>
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Title</label>
                            <input type="text" class="form-control" id="moduleTitle" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="moduleDescription" rows="3" required></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Duration (Min)</label>
                            <input type="number" class="form-control" id="moduleDuration" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Display Order</label>
                            <input type="number" class="form-control" id="moduleOrder" value="0">
                        </div>
                        <div class="col-md-4 mb-3 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="modulePublished">
                                <label class="form-check-label">Published</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveModule()">Save Module</button>
            </div>
        </div>
    </div>
</div>

<!-- Lessons Section (hidden until a module is selected) -->
<div class="card mt-4" id="lessonsSection" style="display: none;">
    <div class="card-header d-flex justify-content-between align-items-center bg-transparent border-0 pt-4 px-4">
        <h3 class="mb-0">Lessons: <span id="selectedModuleTitle" class="text-primary"></span></h3>
        <button class="btn btn-primary" onclick="showLessonForm()">
            <i class="fas fa-plus"></i> Add Lesson
        </button>
    </div>
    <div class="card-body px-4 pb-4">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Title</th>
                        <th>Duration</th>
                        <th>Preview</th>
                        <th>Published</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="lessonsTable">
                    <tr>
                        <td colspan="6" class="text-center text-muted">No lessons loaded.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Lesson Add/Edit Modal -->
<div class="modal fade" id="lessonModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="lessonModalTitle">Add Lesson</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="lessonForm">
                    <input type="hidden" id="lessonId">
                    <input type="hidden" id="lessonModuleId">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control" id="lessonTitle" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="lessonDescription" rows="3"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Duration (Seconds)</label>
                            <input type="number" class="form-control" id="lessonDuration" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Display Order</label>
                            <input type="number" class="form-control" id="lessonOrder" value="0" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-video me-1 text-primary"></i> VdoCipher Video ID (Full Lesson)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-key"></i></span>
                            <input type="text" class="form-control" id="lessonVideoUrl"
                                   placeholder="e.g. c2d8e1d68ba5449343adb7a66f4c6ed3">
                        </div>
                        <div class="form-text text-muted mt-1">
                            <i class="fas fa-info-circle me-1"></i>
                            Paste the <strong>Video ID</strong> from your VdoCipher dashboard for the <strong>Full Lesson</strong> (only played after user enrolls).
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-play-circle me-1 text-success"></i> VdoCipher Preview Video ID
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-key"></i></span>
                            <input type="text" class="form-control" id="lessonPreviewVideoId"
                                   placeholder="e.g. a1b2c3d4e5f6...">
                        </div>
                        <div class="form-text text-muted mt-1">
                            <i class="fas fa-info-circle me-1"></i>
                            Paste the <strong>Video ID</strong> from your VdoCipher dashboard for the <strong>Preview Clip</strong> (short teaser playable by everyone).
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="lessonIsPreview">
                                <label class="form-check-label">Is Preview (Free lesson)</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="lessonPublished">
                                <label class="form-check-label">Published</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveLesson()">Save Lesson</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            populateCourseDropdowns();
        });
    </script>
}
