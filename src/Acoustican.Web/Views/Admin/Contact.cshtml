@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Contact Messages";
    ViewData["ActivePage"] = "contact";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Contact Messages</h2>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>From</th>
                        <th>Email</th>
                        <th>Subject</th>
                        <th>Received At</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="contactMessagesTable">
                    <tr>
                        <td colspan="6" class="text-center text-muted">Loading contact messages...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Message Detail Modal -->
<div class="modal fade" id="messageDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Message Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="messageDetailContent">
                <!-- Content will be populated via JS -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="markAsReadBtn" onclick="markCurrentMessageAsRead()">Mark as Read</button>
                <button type="button" class="btn btn-danger" id="deleteMessageBtn" onclick="deleteCurrentMessage()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentMessageId = null;

        document.addEventListener('DOMContentLoaded', () => {
            loadContactMessages();
        });

        async function loadContactMessages() {
            const response = await fetch('/api/contact');
            const messages = await response.json();
            const tbody = document.getElementById('contactMessagesTable');

            if (!messages || messages.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No messages found</td></tr>';
                if ($.fn.DataTable.isDataTable('#contactMessagesTable')) {
                    $('#contactMessagesTable').closest('table').DataTable().destroy();
                }
                return;
            }

            tbody.innerHTML = messages.map(m => `
                <tr>
                    <td class="fw-semibold">${m.name}</td>
                    <td><a href="mailto:${m.email}" class="text-primary text-decoration-none">${m.email}</a></td>
                    <td>${m.subject}</td>
                    <td>${new Date(m.createdAt).toLocaleString()}</td>
                    <td>
                        ${m.isRead 
                            ? '<span class="badge-pill-custom badge-status-read"><i class="fas fa-check-circle me-1"></i>Read</span>' 
                            : '<span class="badge-pill-custom badge-status-unread"><i class="fas fa-exclamation-circle me-1"></i>Unread</span>'}
                    </td>
                    <td>
                        <button class="btn-action btn-action-edit" onclick="showMessageDetail(${m.id})" title="View Message">
                            <i class="fas fa-eye"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
            
            initOrReinitDataTable('#contactMessagesTable', {
                order: [[3, "desc"]]
            });
        }

        async function showMessageDetail(id) {
            currentMessageId = id;
            const response = await fetch(`/api/contact/${id}`);
            const message = await response.json();

            document.getElementById('messageDetailContent').innerHTML = `
                <div class="mb-3">
                    <label class="form-label text-muted">From</label>
                    <p><strong>${message.name}</strong> (${message.email})</p>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">Subject</label>
                    <p><strong>${message.subject}</strong></p>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">Message</label>
                    <p>${message.message}</p>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">Received At</label>
                    <p>${new Date(message.createdAt).toLocaleString()}</p>
                </div>
            `;

            const markAsReadBtn = document.getElementById('markAsReadBtn');
            markAsReadBtn.style.display = message.isRead ? 'none' : 'inline-block';

            const modal = new bootstrap.Modal(document.getElementById('messageDetailModal'));
            modal.show();
        }

        async function markCurrentMessageAsRead() {
            if (!currentMessageId) return;
            
            await fetch(`/api/contact/${currentMessageId}/mark-read`, { method: 'PUT' });
            await loadContactMessages();
            
            const modal = bootstrap.Modal.getInstance(document.getElementById('messageDetailModal'));
            modal.hide();
        }

        async function deleteCurrentMessage() {
            if (!currentMessageId) return;
            
            if (confirm('Are you sure you want to delete this message?')) {
                await fetch(`/api/contact/${currentMessageId}`, { method: 'DELETE' });
                await loadContactMessages();
                
                const modal = bootstrap.Modal.getInstance(document.getElementById('messageDetailModal'));
                modal.hide();
            }
        }
    </script>
}
