@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>Acoustican Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <script>
        if (localStorage.getItem('adminToken')) {
            window.location.href = '/admin/dashboard';
        }
    </script>

    <style>
        :root {
            --primary: #f5a623;
            --dark: #0a0a0b;
            --darker: #16161a;
            --light-text: #ffffff;
            --muted-text: #a0a0a8;
        }

        *, *::before, *::after { box-sizing: border-box; color-scheme: dark; }

        body {
            background: var(--dark);
            color: var(--light-text);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            margin: 0;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 80% 50% at 20% 40%, rgba(245, 166, 35, 0.07) 0%, transparent 60%),
                radial-gradient(ellipse 60% 60% at 80% 70%, rgba(52, 152, 219, 0.04) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
            z-index: 0;
        }

        .login-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 440px;
            padding: 24px 20px;
        }

        .login-logo {
            text-align: center;
            margin-bottom: 28px;
        }

        .logo-icon {
            width: 58px;
            height: 58px;
            background: linear-gradient(135deg, var(--primary), #d48a15);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #0a0a0b;
            margin-bottom: 12px;
            box-shadow: 0 8px 28px rgba(245, 166, 35, 0.28);
        }

        .login-logo h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--light-text);
            margin: 0 0 4px;
        }

        .login-logo p {
            color: var(--muted-text);
            font-size: 0.83rem;
            margin: 0;
        }

        .login-card {
            background: rgba(22, 22, 26, 0.88);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid #222228;
            border-radius: 16px;
            padding: 36px 32px;
            box-shadow: 0 28px 72px rgba(0,0,0,0.55), inset 0 0 0 1px rgba(255,255,255,0.03);
        }

        .login-card h2 {
            font-size: 1.2rem;
            font-weight: 700;
            margin: 0 0 4px;
        }

        .login-subtitle {
            color: var(--muted-text);
            font-size: 0.85rem;
            margin: 0 0 28px;
        }

        .form-label {
            color: var(--muted-text);
            font-size: 0.76rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            margin-bottom: 6px;
            display: block;
        }

        .input-wrapper { position: relative; }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #44444e;
            font-size: 0.82rem;
            pointer-events: none;
            transition: color 0.2s;
        }

        .form-control {
            width: 100%;
            background: #0e0e12;
            color: var(--light-text);
            border: 1px solid #2a2a35;
            border-radius: 10px;
            padding: 11px 14px 11px 38px;
            font-size: 0.9rem;
            transition: border-color 0.25s, box-shadow 0.25s;
            outline: none;
        }

        .form-control::placeholder { color: #3a3a46; }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.14);
        }

        .form-control:focus + .input-icon,
        .input-wrapper:focus-within .input-icon {
            color: var(--primary);
        }

        .forgot-link {
            color: var(--primary);
            text-decoration: none;
            font-size: 0.81rem;
            transition: opacity 0.2s;
        }

        .forgot-link:hover { opacity: 0.75; color: var(--primary); }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, var(--primary) 0%, #d4880f 100%);
            border: none;
            color: #0a0a0b;
            font-weight: 700;
            font-size: 0.93rem;
            letter-spacing: 0.02em;
            border-radius: 10px;
            padding: 12px;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 18px rgba(245, 166, 35, 0.28);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(245, 166, 35, 0.38);
        }

        .btn-login:active { transform: translateY(0); }

        .divider {
            border: none;
            border-top: 1px solid #1e1e24;
            margin: 24px 0;
        }

        .back-link {
            color: var(--muted-text);
            text-decoration: none;
            font-size: 0.83rem;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            transition: color 0.2s;
        }

        .back-link:hover { color: var(--light-text); }

        .error-box {
            background: rgba(231, 76, 60, 0.09);
            border: 1px solid rgba(231, 76, 60, 0.22);
            color: #e05c4c;
            border-radius: 10px;
            font-size: 0.86rem;
            padding: 10px 14px;
            margin-top: 14px;
            display: none;
        }

        .error-box.visible { display: block; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-logo">
            <div class="logo-icon">
                <i class="fas fa-music"></i>
            </div>
            <h1>Acoustican</h1>
            <p>Admin Control Panel</p>
        </div>

        <div class="login-card">
            <h2>Welcome back</h2>
            <p class="login-subtitle">Sign in to manage your platform</p>

            <form onsubmit="handleLogin(event)">
                <div class="mb-3">
                    <label class="form-label" for="loginEmail">Email Address</label>
                    <div class="input-wrapper">
                        <input type="email" class="form-control" id="loginEmail"
                               placeholder="admin@acoustican.com" required>
                        <i class="fas fa-envelope input-icon"></i>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label" for="loginPassword">Password</label>
                    <div class="input-wrapper">
                        <input type="password" class="form-control" id="loginPassword"
                               placeholder="••••••••" required>
                        <i class="fas fa-lock input-icon"></i>
                    </div>
                </div>
                <div class="text-end mb-4" style="margin-top: 8px;">
                    <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                </div>
                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt me-2"></i> Sign In
                </button>

                <div class="text-center mt-3">
                    <a class="btn btn-dark w-100" href="/api/auth/google/login" style="border:1px solid #2a2a35;">
                        <i class="fab fa-google me-2"></i> Login with Google
                    </a>
                </div>
            </form>


            <div id="loginError"></div>

            <hr class="divider">
            <div class="text-center">
                <a href="/" class="back-link">
                    <i class="fas fa-arrow-left"></i> Back to Home Page
                </a>
            </div>
        </div>
    </div>

    <script src="/js/admin.js"></script>
</body>
</html>
