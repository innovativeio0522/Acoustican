@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>Acoustican Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <script>
        // If already logged in, redirect to dashboard
        if (localStorage.getItem('adminToken')) {
            window.location.href = '/admin/dashboard';
        }
    </script>
    
    <style>
        :root {
            --primary: #f5a623;
            --dark: #0a0a0b;
            --darker: #16161a;
            --light-text: #ffffff;
            --muted-text: #a0a0a8;
        }

        * {
            color-scheme: dark;
        }

        body {
            background: var(--dark);
            color: var(--light-text);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        .card {
            background: var(--darker);
            border: 1px solid #222228;
            color: var(--light-text);
        }

        .btn-primary {
            background: var(--primary);
            border: none;
            color: var(--dark);
            font-weight: 600;
        }

        .btn-primary:hover {
            background: #e0951a;
            color: var(--dark);
        }

        .form-control {
            background: var(--darker);
            color: var(--light-text);
            border: 1px solid #222228;
        }

        .form-control:focus {
            background: var(--darker);
            color: var(--light-text);
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(245, 166, 35, 0.25);
        }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="card" style="width: 100%; max-width: 400px;">
            <div class="card-body p-5">
                <h2 class="text-center mb-4">Acoustican Admin</h2>
                <form onsubmit="handleLogin(event)">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" id="loginEmail" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" id="loginPassword" required>
                        <div class="mt-2 text-end">
                            <a href="/forgot-password" class="text-decoration-none" style="color:#f5a623; font-size: 0.9rem;">
                                Forgot password?
                            </a>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mb-3">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </button>
                    <div class="text-center mt-3">
                        <a href="/" class="btn btn-link text-primary text-decoration-none">
                            <i class="fas fa-arrow-left"></i> Back to Home Page
                        </a>
                    </div>
                </form>
                <div id="loginError" class="mt-3"></div>
            </div>
        </div>
    </div>

    <script src="/js/admin.js"></script>
</body>
</html>
