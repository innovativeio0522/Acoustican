<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>@ViewData["Title"] — The Acoustican</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <link rel="stylesheet" href="/style.css?v=@DateTime.UtcNow.Ticks">
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- Ambient Glows -->
    <div class="ambient-glow glow-top-left"></div>
    <div class="ambient-glow glow-mid-right"></div>

    <!-- NAVIGATION -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">
                <div class="logo-icon">🎸</div>
                The Acoustican
            </a>
            <ul class="nav-links">
                <li><a href="/courses" class='@(ViewData["ActivePage"]?.ToString() == "Courses" ? "nav-active" : "")'>Courses</a></li>
                <li><a href="/#about">About</a></li>
                <li><a href="/#contact">Contact</a></li>
            </ul>
            <div class="nav-actions">
                <!-- Cart Icon Button -->
                <button type="button" class="btn-cart-toggle" onclick="window.GVCart.openDrawer()" aria-label="View Cart">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"/>
                        <circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                    <span class="cart-badge">0</span>
                </button>

                <div id="userProfile" class="user-profile d-none">
                    <button class="user-profile-btn" id="userDropdownToggle">
                        <span class="user-avatar-icon">👤</span>
                        <span id="userFullName" class="user-name"></span>
                        <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="user-dropdown" id="userDropdown">
                        <div class="user-dropdown-header">
                            <div class="user-dropdown-avatar">👤</div>
                            <div>
                                <div class="user-dropdown-name" id="userDropdownName">User</div>
                                <div id="userPlanBadgeRow" class="user-dropdown-plan" style="display:none">
                                    <span id="userPlanLabel"></span>
                                    <button class="cancel-plan-btn" id="cancelPlanBtn" title="Cancel plan">✕ Cancel</button>
                                </div>
                            </div>
                        </div>
                        <div class="user-dropdown-divider"></div>
                        <a href="/orders" class="user-dropdown-item">📦 My Orders</a>
                        <button onclick="handleLogout()" class="user-dropdown-item user-dropdown-logout">🚪 Sign Out</button>
                    </div>
                </div>
                <div id="authActions" class="auth-actions">
                    <button onclick="openAuthModal('login')" class="btn-login">Login</button>
                    <a href="/courses" class="nav-cta">Get Started</a>
                </div>
            </div>
            <button class="mobile-menu-btn">☰</button>
        </div>
    </nav>

    @RenderBody()

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href="/" class="logo">
                    <div class="logo-icon">🎸</div>
                    The Acoustican
                </a>
                <p>Master your instrument with the world's most immersive online guitar education platform.</p>
                <div class="footer-social">
                    <a href="#">𝕏</a>
                    <a href="#">📷</a>
                    <a href="#">▶</a>
                </div>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/courses">Courses</a></li>
                    <li><a href="#">Instructor Team</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <ul>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Support Center</a></li>
                    <li><a href="#">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Legal</h4>
                <ul>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© @DateTime.Now.Year The Acoustican. All rights reserved.</p>
            <p>Made with ❤️ for Musicians</p>
        </div>
    </footer>

    <!-- AUTH MODAL -->
    <div id="authModal" class="auth-modal d-none" data-pending-tier="">
        <div class="auth-modal-backdrop" onclick="closeAuthModal()"></div>
        <div class="auth-modal-content">
            <button class="auth-modal-close" onclick="closeAuthModal()">✕</button>

            <!-- Logo -->
            <div class="auth-logo">
                <div class="auth-logo-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
                </div>
                <span>Acoustican</span>
            </div>

            <!-- LOGIN VIEW -->
            <div id="loginView">
                <div class="auth-header">
                    <h2>Welcome back</h2>
                    <p>Continue your musical journey</p>
                </div>
                <div id="loginError" class="auth-error"></div>
                <form class="auth-form" onsubmit="handleLogin(event)">
                    <div class="form-group">
                        <label>Email Address</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            <input type="email" id="loginEmail" placeholder="name@example.com" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input type="password" id="loginPassword" placeholder="••••••••" required>
                        </div>
                        <div style="text-align: right; margin-top: 6px;">
                            <a href="/forgot-password" class="auth-forgot-link">Forgot password?</a>
                        </div>
                    </div>
                    <button type="submit" class="auth-submit-btn">Sign In</button>
                </form>
                <div class="auth-social-separator">
                    <span>or</span>
                </div>
                <div class="auth-social-login">
                    <a href="/api/auth/google/login" class="auth-google-btn">
                        <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                        </svg>
                        <span>Continue with Google</span>
                    </a>
                </div>
                <div class="auth-divider"></div>
                <div class="auth-footer">
                    Don't have an account? <button onclick="switchAuthView('signup')">Sign Up</button>
                </div>
            </div>

            <!-- SIGNUP VIEW -->
            <div id="signupView" class="d-none">
                <div class="auth-header">
                    <h2>Create account</h2>
                    <p>Start your guitar mastery today</p>
                </div>
                <div id="signupError" class="auth-error"></div>
                <form class="auth-form" onsubmit="handleSignup(event)">
                    <div class="form-group">
                        <label>Full Name</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <input type="text" id="signupName" placeholder="John Doe" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            <input type="email" id="signupEmail" placeholder="name@example.com" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input type="password" id="signupPassword" placeholder="••••••••" required>
                        </div>
                    </div>
                    <button type="submit" class="auth-submit-btn">Create Account</button>
                </form>
                <div class="auth-social-separator">
                    <span>or</span>
                </div>
                <div class="auth-social-login">
                    <a href="/api/auth/google/login" class="auth-google-btn">
                        <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                        </svg>
                        <span>Continue with Google</span>
                    </a>
                </div>
                <div class="auth-divider"></div>
                <div class="auth-footer">
                    Already have an account? <button onclick="switchAuthView('login')">Sign In</button>
                </div>
            </div>
        </div>
    </div>


    <!-- ENROLLMENT CHECKOUT MODAL -->
    <div class="enroll-modal" id="enrollModal">
        <div class="enroll-modal-backdrop"></div>
        <div class="enroll-modal-content">
            <button class="enroll-modal-close">✕</button>
            <h3>Join The Acoustican</h3>
            <p class="selected-plan-text">Plan Selected: <span>Pro Track</span></p>
            <form id="enrollForm">
                <div class="form-group">
                    <label for="enrollName">Full Name</label>
                    <input type="text" id="enrollName" required placeholder="e.g. Jimi Hendrix">
                </div>
                <div class="form-group">
                    <label for="enrollEmail">Email Address</label>
                    <input type="email" id="enrollEmail" required placeholder="e.g. jimi@theacoustican.com">
                </div>
                <div class="form-group">
                    <label for="enrollPhone">Phone Number</label>
                    <input type="tel" id="enrollPhone" required placeholder="e.g. +91 99999 88888">
                </div>
                <button type="submit" class="btn-primary"
                        style="width: 100%; justify-content: center; margin-top: 10px;">Confirm & Enroll</button>
            </form>
        </div>
    </div>

    <!-- TOAST NOTIFICATION -->
    <div class="toast-notification" id="toast">
        <div class="toast-icon">🎸</div>
        <div class="toast-content">
            <div class="toast-title">Success</div>
            <div class="toast-message">Enrollment Successful! Welcome to The Acoustican.</div>
        </div>
        <div class="toast-progress"></div>
    </div>

    <!-- CART TOAST -->
    <div id="cartToast" class="cart-toast">
        <div class="cart-toast-icon">🛒</div>
        <div class="cart-toast-body">
            <h5 class="cart-toast-title">Cart</h5>
            <p class="cart-toast-message">Item added</p>
        </div>
    </div>

    <!-- CART DRAWER -->
    <div id="cartDrawer" class="cart-drawer-container">
        <div class="cart-drawer-backdrop"></div>
        <div class="cart-drawer">
            <div class="cart-drawer-header">
                <h3>Shopping Cart</h3>
                <button class="cart-drawer-close" aria-label="Close cart">✕</button>
            </div>
            <div class="cart-drawer-content" id="drawerItems">
                <!-- Dynamic cart items here -->
            </div>
            <div class="cart-drawer-footer">
                <div class="cart-drawer-total-row">
                    <span>Total:</span>
                    <strong id="drawerTotal">₹0</strong>
                </div>
                <div class="cart-drawer-actions">
                    <a href="/cart" class="btn-view-cart">View Cart</a>
                    <button type="button" class="btn-checkout-fast" onclick="window.location.href='/cart'">Checkout</button>
                </div>
            </div>
        </div>
    </div>

    <!-- VIDEO LIGHTBOX MODAL -->
    <div class="video-modal" id="videoModal">
        <div class="video-modal-backdrop"></div>
        <div class="video-modal-content">
            <button class="video-modal-close">✕</button>
            <div class="video-iframe-container">
                <video id="previewVideo" controls playsinline src="/videos/5467-184226823_medium.mp4"></video>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="/js/gsap.min.js"></script>
    <script src="/js/ScrollTrigger.min.js"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/cart.js?v=@DateTime.UtcNow.Ticks"></script>
    <script src="/script.js?v=@DateTime.UtcNow.Ticks"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
