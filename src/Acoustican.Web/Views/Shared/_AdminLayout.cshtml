<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - Acoustican Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/js/dataTables.bootstrap5.min.css" rel="stylesheet">

    <script>
        if (!localStorage.getItem('adminToken')) {
            window.location.href = '/admin';
        }
    </script>

    <style>
        :root {
            --primary: #f5a623;
            --dark: #0a0a0b;
            --darker: #16161a;
            --light-text: #ffffff;
            --muted-text: #a0a0a8;
        }

        * {
            color-scheme: dark;
        }

        body {
            background: var(--dark);
            color: var(--light-text);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        .navbar {
            background: var(--darker) !important;
            border-bottom: 1px solid #222228;
        }

        .sidebar {
            background: var(--darker);
            border-right: 1px solid #222228;
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            height: 100vh;
            overflow-y: auto;
            padding-top: 60px;
        }

        .main-content {
            margin-left: 250px;
            padding: 80px 20px 20px 20px;
        }

        .nav-link {
            color: var(--muted-text) !important;
            border-left: 3px solid transparent;
            padding-left: 15px;
            margin-bottom: 5px;
            transition: all 0.3s;
        }

        .nav-link:hover,
        .nav-link.active {
            color: var(--primary) !important;
            border-left-color: var(--primary);
        }

        .card {
            background: var(--darker);
            border: 1px solid #222228;
            color: var(--light-text);
            border-radius: 10px;
            overflow: hidden;
        }

        .card-header {
            background: #111115 !important;
            border-bottom: 1px solid #222228 !important;
            color: var(--light-text) !important;
            padding: 14px 20px;
            font-weight: 600;
        }

        .card-footer {
            background: #111115 !important;
            border-top: 1px solid #222228 !important;
            color: var(--muted-text) !important;
        }

        .border-bottom {
            border-bottom-color: #222228 !important;
        }

        .btn-primary {
            background: var(--primary);
            border: none;
            color: var(--dark);
            font-weight: 600;
        }

        .btn-primary:hover {
            background: #e0951a;
            color: var(--dark);
        }

        .btn-secondary {
            background: #32323a;
            border: 1px solid #44444a;
            color: var(--light-text);
        }

        .btn-secondary:hover {
            background: #40404a;
            color: var(--light-text);
            border-color: #55555a;
        }

        .badge-primary {
            background: var(--primary);
            color: var(--dark);
        }

        /* Premium Table Customizations */
        .table-responsive {
            scrollbar-width: thin;
            scrollbar-color: #32323a var(--darker);
        }
        .table-responsive::-webkit-scrollbar {
            height: 6px;
            width: 6px;
        }
        .table-responsive::-webkit-scrollbar-thumb {
            background: #32323a;
            border-radius: 3px;
        }
        .table-responsive::-webkit-scrollbar-track {
            background: var(--darker);
        }

        .table {
            background: var(--darker) !important;
            color: var(--light-text) !important;
            border-collapse: separate !important;
            border-spacing: 0 !important;
            margin-bottom: 0 !important;
            width: 100% !important;
            border: none !important;
        }

        .table th {
            text-transform: uppercase !important;
            font-size: 0.725rem !important;
            font-weight: 700 !important;
            letter-spacing: 0.08em !important;
            color: var(--muted-text) !important;
            border-bottom: 2px solid #222228 !important;
            padding: 14px 16px !important;
            background: #111115 !important;
        }

        .table td {
            padding: 14px 16px !important;
            vertical-align: middle !important;
            border-bottom: 1px solid #222228 !important;
            color: #e2e2e9 !important;
            background: transparent !important;
        }

        .table tbody tr {
            transition: all 0.2s ease;
            border-bottom: 1px solid #222228 !important;
        }

        .table tbody tr:hover {
            background: #1b1b22 !important;
        }

        .table tbody tr.table-active {
            background: rgba(245, 166, 35, 0.1) !important;
            border-left: 3px solid var(--primary) !important;
        }
        
        /* Badges & Tags design */
        .badge-pill-custom {
            padding: 5px 12px;
            font-size: 0.725rem;
            font-weight: 600;
            border-radius: 30px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        
        .badge-status-published, .badge-status-read, .badge-status-yes {
            background: rgba(46, 204, 113, 0.12) !important;
            color: #2ecc71 !important;
            border: 1px solid rgba(46, 204, 113, 0.25);
        }
        
        .badge-status-draft, .badge-status-no {
            background: rgba(108, 117, 125, 0.12) !important;
            color: #a0a0a8 !important;
            border: 1px solid rgba(108, 117, 125, 0.25);
        }
        
        .badge-status-pending, .badge-status-unread {
            background: rgba(245, 166, 35, 0.12) !important;
            color: #f5a623 !important;
            border: 1px solid rgba(245, 166, 35, 0.25);
        }

        .badge-status-popular {
            background: rgba(245, 166, 35, 0.15) !important;
            color: var(--primary) !important;
            border: 1px solid rgba(245, 166, 35, 0.3);
        }
        
        .badge-level {
            background: rgba(52, 152, 219, 0.12) !important;
            color: #3498db !important;
            border: 1px solid rgba(52, 152, 219, 0.25);
        }

        /* Action buttons */
        .btn-action {
            width: 32px;
            height: 32px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            transition: all 0.2s ease;
            font-size: 0.85rem;
            background: #1f1f26;
            border: 1px solid #32323a;
            color: var(--muted-text) !important;
            margin-right: 4px;
        }

        .btn-action:hover {
            color: #ffffff !important;
        }

        .btn-action-edit:hover {
            background: rgba(245, 166, 35, 0.15) !important;
            border-color: var(--primary) !important;
            color: var(--primary) !important;
        }

        .btn-action-delete:hover {
            background: rgba(231, 76, 60, 0.15) !important;
            border-color: #e74c3c !important;
            color: #e74c3c !important;
        }

        .btn-action-toggle:hover {
            background: rgba(46, 204, 113, 0.15) !important;
            border-color: #2ecc71 !important;
            color: #2ecc71 !important;
        }

        .btn-action-toggle-off:hover {
            background: rgba(108, 117, 125, 0.15) !important;
            border-color: #a0a0a8 !important;
            color: #a0a0a8 !important;
        }

        /* DataTables custom controls styles */
        .dataTables_wrapper {
            padding: 10px 0;
        }

        .dataTables_wrapper .dataTables_length select {
            background-color: #111115 !important;
            border: 1px solid #222228 !important;
            color: var(--light-text) !important;
            border-radius: 6px;
            padding: 4px 24px 4px 8px;
            font-size: 0.85rem;
        }

        .dataTables_wrapper .dataTables_filter input {
            background-color: #111115 !important;
            border: 1px solid #222228 !important;
            color: var(--light-text) !important;
            border-radius: 30px;
            padding: 6px 16px;
            font-size: 0.85rem;
            min-width: 220px;
            transition: all 0.3s ease;
        }

        .dataTables_wrapper .dataTables_filter input:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.15) !important;
            outline: none;
        }

        .dataTables_wrapper .dataTables_info {
            color: var(--muted-text) !important;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding-top: 15px;
        }

        .dataTables_wrapper .pagination {
            margin-top: 12px;
            gap: 4px;
            justify-content: flex-end;
        }

        .dataTables_wrapper .page-item .page-link {
            background-color: #111115 !important;
            border: 1px solid #222228 !important;
            color: var(--muted-text) !important;
            border-radius: 6px;
            padding: 6px 12px;
            font-size: 0.85rem;
            transition: all 0.2s ease;
            box-shadow: none !important;
        }

        .dataTables_wrapper .page-item:hover .page-link {
            background-color: #1f1f26 !important;
            color: #ffffff !important;
            border-color: #32323a !important;
        }

        .dataTables_wrapper .page-item.active .page-link {
            background-color: var(--primary) !important;
            border-color: var(--primary) !important;
            color: var(--dark) !important;
            font-weight: 600;
            box-shadow: 0 0 8px rgba(245, 166, 35, 0.3) !important;
        }

        .dataTables_wrapper .page-item.disabled .page-link {
            background-color: #0d0d0f !important;
            border-color: #1a1a20 !important;
            color: #55555d !important;
        }
        
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter {
            margin-bottom: 15px;
            color: var(--muted-text);
            font-size: 0.85rem;
        }

        .form-control,
        .form-select {
            background: #111115;
            color: var(--light-text);
            border: 1px solid #222228;
        }

        .form-control:focus,
        .form-select:focus {
            background: #111115;
            color: var(--light-text);
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(245, 166, 35, 0.25);
        }

        .form-control::placeholder {
            color: #55555d;
        }

        textarea.form-control {
            resize: vertical;
            min-height: 100px;
        }

        .form-label {
            color: var(--muted-text);
            font-size: 0.82rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 6px;
        }

        .form-check-input {
            background-color: #111115;
            border-color: #32323a;
        }

        .form-check-input:checked {
            background-color: var(--primary);
            border-color: var(--primary);
        }

        /* Input group */
        .input-group-text {
            background: #111115;
            border: 1px solid #222228;
            color: var(--muted-text);
        }

        /* Alert overrides */
        .alert-success {
            background: rgba(46, 204, 113, 0.1);
            border: 1px solid rgba(46, 204, 113, 0.25);
            color: #2ecc71;
        }

        .alert-danger {
            background: rgba(231, 76, 60, 0.1);
            border: 1px solid rgba(231, 76, 60, 0.25);
            color: #e74c3c;
        }

        .alert-warning {
            background: rgba(245, 166, 35, 0.1);
            border: 1px solid rgba(245, 166, 35, 0.25);
            color: var(--primary);
        }

        .alert-info {
            background: rgba(52, 152, 219, 0.1);
            border: 1px solid rgba(52, 152, 219, 0.25);
            color: #3498db;
        }

        .modal-content {
            background: var(--darker);
            border: 1px solid #222228;
            color: var(--light-text);
        }

        .modal-header, .modal-footer {
            border-color: #222228;
        }

        .btn-close {
            filter: invert(1);
        }

        .stat-card {
            background: linear-gradient(135deg, var(--darker), #1a1a20);
            border: 1px solid #222228;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }

        .stat-label {
            color: var(--muted-text);
            font-size: 0.9rem;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-dark fixed-top">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                <i class="fas fa-music"></i> Acoustican Admin
            </span>
            <span class="text-muted" id="userDisplay">
                <i class="fas fa-user-circle"></i> <span id="userName">Admin</span>
                <button class="btn btn-sm btn-outline-danger ms-2" onclick="logout()">Logout</button>
            </span>
        </div>
    </nav>

    <nav class="sidebar">
        <div class="position-sticky">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "dashboard" ? "active" : "")" href="/admin/dashboard">
                        <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "courses" ? "active" : "")" href="/admin/courses">
                        <i class="fas fa-graduation-cap me-2"></i> Courses
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "modules" ? "active" : "")" href="/admin/modules">
                        <i class="fas fa-book me-2"></i> Modules
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "testimonials" ? "active" : "")" href="/admin/testimonials">
                        <i class="fas fa-star me-2"></i> Testimonials
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "pricing" ? "active" : "")" href="/admin/pricing">
                        <i class="fas fa-tags me-2"></i> Pricing
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "hero" ? "active" : "")" href="/admin/hero">
                        <i class="fas fa-image me-2"></i> Hero Section
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "contact" ? "active" : "")" href="/admin/contact">
                        <i class="fas fa-envelope me-2"></i> Contact
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "files" ? "active" : "")" href="/admin/files">
                        <i class="fas fa-folder-open me-2"></i> Files
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="/js/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/jquery.dataTables.min.js"></script>
    <script src="/js/dataTables.bootstrap5.min.js"></script>
    <script src="/js/admin.js"></script>
    
    <script>
        const userDataStr = localStorage.getItem('userData');
        if (userDataStr) {
            try {
                const userData = JSON.parse(userDataStr);
                if (userData && userData.fullName) {
                    document.getElementById('userName').textContent = userData.fullName;
                }
            } catch (e) {
                console.error("Error parsing user data", e);
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
