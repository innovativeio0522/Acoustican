@{
    ViewData["Title"] = "Order History";
}

@section Styles {
    <link rel="stylesheet" href="/cart.css?v=@DateTime.UtcNow.Ticks">
}

<!-- PAGE HERO -->
<section class="cart-hero">
    <div class="cart-hero-inner">
        <h1 class="cart-hero-title">Your <span>Orders</span></h1>
        <p class="cart-hero-desc">Track your enrolled courses, view order summaries, and manage your learning paths.</p>
    </div>
</section>

<!-- SUBSCRIPTION CARD -->
<div class="cart-container" id="subscriptionSection" style="display:none; padding-bottom: 0;">
    <div class="order-card" style="margin-bottom: 0;">
        <div class="order-card-header">
            <div class="order-header-left">
                <div class="order-header-stat">
                    <span class="order-stat-label">Active Plan</span>
                    <span class="order-stat-value" id="subPlanName" style="color: #f5a623;">—</span>
                </div>
                <div class="order-header-stat">
                    <span class="order-stat-label">Price</span>
                    <span class="order-stat-value total" id="subPlanPrice">—</span>
                </div>
                <div class="order-header-stat">
                    <span class="order-stat-label">Since</span>
                    <span class="order-stat-value" id="subStartDate">—</span>
                </div>
            </div>
            <div class="order-header-right">
                <span class="status-badge" style="background: rgba(74,222,128,0.15); color: #4ade80; border: 1px solid rgba(74,222,128,0.3);">Active</span>
                <button class="btn-order-cancel" id="cancelSubBtn">Cancel Plan</button>
            </div>
        </div>
    </div>
</div>

<!-- MAIN ORDERS CONTENT -->
<div class="cart-container" id="ordersContainer">
    <!-- Gated Access (if not logged in) -->
    <div id="ordersGated" class="cart-empty-state" style="display: none;">
        <span class="empty-icon">🔒</span>
        <h2>Access Enrolled Courses</h2>
        <p>Please log in to your account to view your order history and access your dashboard.</p>
        <button type="button" class="btn-shop-courses" onclick="window.openAuthModal('login')">
            Sign In to Account
        </button>
    </div>

    <!-- Loading State -->
    <div id="ordersLoading" style="text-align: center; padding: 60px 0;">
        <div class="drawer-empty-icon" style="animation: pulse 1.5s infinite; font-size: 3rem;">📋</div>
        <p style="color: var(--text-muted); margin-top: 16px;">Loading your purchase history...</p>
    </div>

    <!-- Empty State (hidden by default) -->
    <div id="ordersEmpty" class="cart-empty-state" style="display: none;">
        <span class="empty-icon">📋</span>
        <h2>No Orders Found</h2>
        <p>You haven't purchased any courses yet. Let's find your first course to get started!</p>
        <a href="/courses" class="btn-shop-courses">
            Browse Courses
        </a>
    </div>

    <!-- Active Orders List (hidden by default) -->
    <div id="ordersList" class="orders-layout" style="display: none;">
        <!-- Dynamic Order Cards here -->
    </div>
</div>

@section Scripts {
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const gatedEl = document.getElementById('ordersGated');
            const loadingEl = document.getElementById('ordersLoading');
            const emptyEl = document.getElementById('ordersEmpty');
            const listEl = document.getElementById('ordersList');

            async function loadOrders() {
                gatedEl.style.display = 'none';
                loadingEl.style.display = 'block';
                emptyEl.style.display = 'none';
                listEl.style.display = 'none';

                if (!window.GVCart.isLoggedIn()) {
                    loadingEl.style.display = 'none';
                    gatedEl.style.display = 'block';
                    return;
                }

                try {
                    const res = await fetch('/api/orders', { headers: window.GVCart.authHeaders() });
                    if (!res.ok) throw new Error();
                    
                    const data = await res.json();
                    const orders = data.orders || [];

                    loadingEl.style.display = 'none';

                    if (orders.length === 0) {
                        emptyEl.style.display = 'block';
                        return;
                    }

                    listEl.style.display = 'flex';
                    renderOrderCards(orders);
                } catch {
                    loadingEl.style.display = 'none';
                    emptyEl.style.display = 'block';
                    emptyEl.querySelector('p').textContent = 'Could not load orders. Please verify your connection and try again.';
                }
            }

            function renderOrderCards(orders) {
                listEl.innerHTML = orders.map(order => {
                    const date = new Date(order.createdAt).toLocaleDateString('en-IN', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    });

                    const isPending = order.status.toLowerCase() === 'pending';
                    const statusClass = order.status.toLowerCase();

                    return `
                        <div class="order-card" id="order-${order.id}">
                            <div class="order-card-header">
                                <div class="order-header-left">
                                    <div class="order-header-stat">
                                        <span class="order-stat-label">Order Placed</span>
                                        <span class="order-stat-value">${date}</span>
                                    </div>
                                    <div class="order-header-stat">
                                        <span class="order-stat-label">Total Amount</span>
                                        <span class="order-stat-value total">₹${order.totalAmount.toLocaleString('en-IN')}</span>
                                    </div>
                                    <div class="order-header-stat">
                                        <span class="order-stat-label">Order ID</span>
                                        <span class="order-stat-value">#GVA-ORD-${order.id}</span>
                                    </div>
                                </div>
                                <div class="order-header-right">
                                    <span class="status-badge ${statusClass}">${order.status}</span>
                                    ${isPending ? `
                                        <button class="btn-order-pay" onclick="payOrder(${order.id}, this)">Pay Now</button>
                                        <button class="btn-order-cancel" onclick="cancelOrder(${order.id})">Cancel Order</button>
                                    ` : ''}
                                </div>
                            </div>
                            <div class="order-card-body">
                                <div class="order-items-list">
                                    ${order.items.map(item => `
                                        <div class="order-item-row">
                                            <img src="${item.courseThumbnailUrl || 'https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=200&h=120&fit=crop&q=80'}" alt="${item.courseTitle}" class="order-item-thumb">
                                            <div class="order-item-info">
                                                <h4 class="order-item-title">${item.courseTitle}</h4>
                                                <span class="order-item-price">₹${item.price.toLocaleString('en-IN')}</span>
                                            </div>
                                            <div class="order-item-actions">
                                                ${order.status.toLowerCase() === 'confirmed' ? `
                                                    <a href="/courses/${item.courseId}" class="btn-study-now">Study Now</a>
                                                ` : `
                                                    <span class="order-item-locked" style="color: var(--text-muted); font-size: 0.85rem; display: flex; align-items: center; gap: 6px;">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                                        Locked
                                                    </span>
                                                `}
                                            </div>
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
            }

            // Expose payOrder globally
            window.payOrder = async function(orderId, btn) {
                if (btn) {
                    btn.disabled = true;
                    btn.textContent = 'Processing...';
                }

                try {
                    const res = await fetch(`/api/orders/${orderId}`, {
                        headers: window.GVCart.authHeaders()
                    });
                    const data = await res.json();
                    
                    if (res.ok && data.success) {
                        const order = data.order;
                        const totalAmount = order.totalAmount;
                        const items = order.items;

                        const verifyPayment = async (razorpayOrderId, razorpayPaymentId, razorpaySignature) => {
                            try {
                                const verifyRes = await fetch('/api/orders/verify', {
                                    method: 'POST',
                                    headers: window.GVCart.authHeaders(),
                                    body: JSON.stringify({
                                        razorpayOrderId,
                                        razorpayPaymentId,
                                        razorpaySignature
                                    })
                                });
                                const verifyData = await verifyRes.json();

                                if (verifyRes.ok && verifyData.success) {
                                    // Save purchased course titles to local storage for the CourseDetail "Resume Learning" UI check
                                    const enrolledCourses = JSON.parse(localStorage.getItem('enrolledCourses') || '[]');
                                    items.forEach(item => {
                                        if (!enrolledCourses.includes(item.courseTitle)) {
                                            enrolledCourses.push(item.courseTitle);
                                        }
                                    });
                                    localStorage.setItem('enrolledCourses', JSON.stringify(enrolledCourses));
                                    
                                    // Refresh orders list
                                    loadOrders();
                                    alert('Payment successful! Your course access is confirmed.');
                                } else {
                                    alert(verifyData.message || 'Payment verification failed. Please try again.');
                                    resetPayBtn();
                                }
                            } catch {
                                alert('An error occurred during payment verification. Please check your connection.');
                                resetPayBtn();
                            }
                        };

                        const resetPayBtn = () => {
                            if (btn) {
                                btn.disabled = false;
                                btn.textContent = 'Pay Now';
                            }
                        };

                        // Check if we are running in Mock Mode
                        if (order.razorpayOrderId && order.razorpayOrderId.startsWith("order_mock_")) {
                            showMockPaymentModal(order, 
                                (response) => {
                                    verifyPayment(response.razorpay_order_id, response.razorpay_payment_id, response.razorpay_signature);
                                }, 
                                (errorMsg) => {
                                    alert(errorMsg);
                                    resetPayBtn();
                                }
                            );
                        } else {
                            // Real Razorpay Flow
                            const options = {
                                "key": order.razorpayKey,
                                "amount": Math.round(order.totalAmount * 100), // in paise
                                "currency": "INR",
                                "name": "Acoustican",
                                "description": "Course Enrollment Purchase",
                                "order_id": order.razorpayOrderId,
                                "handler": function (response) {
                                    verifyPayment(response.razorpay_order_id, response.razorpay_payment_id, response.razorpay_signature);
                                },
                                "prefill": {
                                    "name": "",
                                    "email": ""
                                },
                                "theme": {
                                    "color": "#f5a623"
                                },
                                "modal": {
                                    "ondismiss": function() {
                                        resetPayBtn();
                                    }
                                }
                            };

                            // Retrieve prefill info if possible
                            try {
                                const userData = JSON.parse(localStorage.getItem('userData'));
                                if (userData) {
                                    options.prefill.name = userData.name || userData.username || "";
                                    options.prefill.email = userData.email || "";
                                }
                            } catch (_) {}

                            const rzp = new Razorpay(options);
                            rzp.on('payment.failed', function (response) {
                                alert("Payment failed: " + response.error.description);
                                resetPayBtn();
                            });
                            rzp.open();
                        }
                    } else {
                        alert(data.message || 'Failed to fetch order details. Please try again.');
                        if (btn) {
                            btn.disabled = false;
                            btn.textContent = 'Pay Now';
                        }
                    }
                } catch (e) {
                    console.error(e);
                    alert('An error occurred. Please check your connection.');
                    if (btn) {
                        btn.disabled = false;
                        btn.textContent = 'Pay Now';
                    }
                }
            };

            function showMockPaymentModal(order, onConfirm, onCancel) {
                const existing = document.getElementById('mockPaymentOverlay');
                if (existing) existing.remove();

                const overlay = document.createElement('div');
                overlay.id = 'mockPaymentOverlay';
                overlay.style.position = 'fixed';
                overlay.style.top = '0';
                overlay.style.left = '0';
                overlay.style.width = '100%';
                overlay.style.height = '100%';
                overlay.style.backgroundColor = 'rgba(10, 10, 12, 0.85)';
                overlay.style.backdropFilter = 'blur(12px)';
                overlay.style.display = 'flex';
                overlay.style.alignItems = 'center';
                overlay.style.justifyContent = 'center';
                overlay.style.zIndex = '99999';
                overlay.style.fontFamily = "'Inter', sans-serif";

                const card = document.createElement('div');
                card.style.background = 'linear-gradient(135deg, #1e1e24, #121216)';
                card.style.border = '1px solid rgba(255, 255, 255, 0.08)';
                card.style.borderRadius = '20px';
                card.style.padding = '32px';
                card.style.width = '100%';
                card.style.maxWidth = '420px';
                card.style.color = '#ffffff';
                card.style.boxShadow = '0 20px 40px rgba(0, 0, 0, 0.5)';
                card.style.textAlign = 'center';

                card.innerHTML = `
                    <div style="font-size: 3rem; margin-bottom: 16px;">🎸</div>
                    <h3 style="margin: 0 0 8px; font-size: 1.5rem; font-weight: 700; background: linear-gradient(90deg, #f5a623, #f8e71c); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        Mock Payment Gateway
                    </h3>
                    <div style="display: inline-block; padding: 4px 10px; font-size: 0.75rem; background: rgba(245, 166, 35, 0.15); border: 1px solid rgba(245, 166, 35, 0.3); border-radius: 20px; color: #f5a623; margin-bottom: 24px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                        Test Mode (No Keys)
                    </div>
                    
                    <div style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 12px; padding: 16px; text-align: left; margin-bottom: 24px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <span style="color: rgba(255, 255, 255, 0.5); font-size: 0.9rem;">Order Reference</span>
                            <span style="font-weight: 600; font-size: 0.9rem;">#GVA-ORD-${order.id}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: rgba(255, 255, 255, 0.5); font-size: 0.9rem;">Amount Due</span>
                            <span style="font-weight: 700; color: #4ade80; font-size: 1.1rem;">₹${order.totalAmount.toLocaleString('en-IN')}</span>
                        </div>
                    </div>

                    <p style="color: rgba(255, 255, 255, 0.6); font-size: 0.9rem; margin-bottom: 24px; line-height: 1.5;">
                        Simulate a transaction outcome to verify backend order validation and user enrollment.
                    </p>

                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <button id="btnMockSuccess" style="background: #22c55e; border: none; border-radius: 10px; padding: 12px; color: #fff; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.2s;">
                            Simulate Successful Payment
                        </button>
                        <button id="btnMockFailure" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 10px; padding: 12px; color: #ef4444; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.2s;">
                            Simulate Failed Payment
                        </button>
                        <button id="btnMockCancel" style="background: transparent; border: none; padding: 8px; color: rgba(255, 255, 255, 0.4); font-size: 0.85rem; cursor: pointer; text-decoration: underline;">
                            Cancel Checkout
                        </button>
                    </div>
                `;

                overlay.appendChild(card);
                document.body.appendChild(overlay);

                document.getElementById('btnMockSuccess').onclick = () => {
                    overlay.remove();
                    onConfirm({
                        razorpay_order_id: order.razorpayOrderId,
                        razorpay_payment_id: "pay_mock_" + Math.random().toString(36).substring(2, 11),
                        razorpay_signature: "sig_mock_" + Math.random().toString(36).substring(2, 11)
                    });
                };

                document.getElementById('btnMockFailure').onclick = () => {
                    overlay.remove();
                    onCancel("Payment simulation failed.");
                };

                document.getElementById('btnMockCancel').onclick = () => {
                    overlay.remove();
                    onCancel("Checkout cancelled by user.");
                };
            }

            // Expose cancelOrder globally
            window.cancelOrder = async function(orderId) {
                if (!confirm('Are you sure you want to cancel this order?')) return;

                const cancelBtn = document.querySelector(`#order-${orderId} .btn-order-cancel`);
                if (cancelBtn) cancelBtn.disabled = true;

                try {
                    const res = await fetch(`/api/orders/${orderId}/cancel`, {
                        method: 'POST',
                        headers: window.GVCart.authHeaders()
                    });
                    const data = await res.json();
                    
                    if (res.ok && data.success) {
                        // Reload order cards
                        loadOrders();
                    } else {
                        alert(data.message || 'Could not cancel order.');
                        if (cancelBtn) cancelBtn.disabled = false;
                    }
                } catch {
                    alert('An error occurred. Please check your connection.');
                    if (cancelBtn) cancelBtn.disabled = false;
                }
            };

            // ===== SUBSCRIPTION SECTION =====
            async function loadSubscription() {
                const headers = window.GVCart.authHeaders();
                if (!headers['Authorization']) return;

                try {
                    const res = await fetch('/api/subscriptions/me', { headers });
                    if (!res.ok) return;
                    const data = await res.json();
                    const sub = data.subscription;
                    if (!sub || sub.status !== 'active') return;

                    const section = document.getElementById('subscriptionSection');
                    const planName = document.getElementById('subPlanName');
                    const planPrice = document.getElementById('subPlanPrice');
                    const startDate = document.getElementById('subStartDate');

                    if (planName) planName.textContent = sub.planName || '—';
                    if (planPrice) planPrice.textContent = sub.planPrice != null ? `₹${sub.planPrice.toLocaleString('en-IN')} / ${sub.billingPeriod || 'month'}` : '—';
                    if (startDate) startDate.textContent = sub.startDate ? new Date(sub.startDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) : '—';
                    if (section) section.style.display = 'block';
                } catch { /* silent */ }
            }

            const cancelSubBtn = document.getElementById('cancelSubBtn');
            if (cancelSubBtn) {
                cancelSubBtn.addEventListener('click', async () => {
                    if (!confirm('Are you sure you want to cancel your subscription? You will lose access to plan benefits.')) return;
                    cancelSubBtn.disabled = true;
                    cancelSubBtn.textContent = 'Cancelling…';
                    try {
                        const res = await fetch('/api/subscriptions/me', {
                            method: 'DELETE',
                            headers: window.GVCart.authHeaders()
                        });
                        if (res.ok) {
                            document.getElementById('subscriptionSection').style.display = 'none';
                            alert('Your subscription has been cancelled.');
                            window.location.reload();
                        } else {
                            alert('Failed to cancel subscription. Please try again.');
                            cancelSubBtn.disabled = false;
                            cancelSubBtn.textContent = 'Cancel Plan';
                        }
                    } catch {
                        alert('Connection error.');
                        cancelSubBtn.disabled = false;
                        cancelSubBtn.textContent = 'Cancel Plan';
                    }
                });
            }

            // Run load on init
            loadSubscription();
            loadOrders();
        });
    </script>
}
