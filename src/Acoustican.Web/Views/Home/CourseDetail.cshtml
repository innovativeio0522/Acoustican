@model CourseDto
@{
    ViewData["Title"] = Model.Title;
    ViewData["ActivePage"] = "Courses";
    var hours = Model.DurationMinutes / 60;
    var mins = Model.DurationMinutes % 60;

    var reviewsCount = Model.Reviews?.Count ?? 0;
    var avgRating = reviewsCount > 0 ? Model.Reviews.Average(r => r.Rating) : 0.0;
    var roundedRating = (int)Math.Round(avgRating);
}

@section Styles {
    <style>
        body.logged-in .lesson-free-preview {
            display: none !important;
        }
        /* Review styling */
        .star-rating-picker {
            display: flex;
            gap: 8px;
            font-size: 1.8rem;
            cursor: pointer;
            margin-bottom: 5px;
        }
        .picker-star {
            color: #4b5563; /* Zinc-600, visible but inactive */
            transition: color 0.15s, transform 0.1s;
        }
        .picker-star:hover {
            transform: scale(1.15);
        }
        .picker-star.hover,
        .picker-star.selected {
            color: #f5a623;
        }
        .review-form-card {
            background: rgba(22, 22, 26, 0.8);
            border: 1px solid #222228;
            border-radius: 12px;
            padding: 24px;
            margin-top: 20px;
        }
        .review-form-card h4 {
            margin-bottom: 20px;
            font-size: 1.2rem;
            font-weight: 700;
        }
        .review-form-card .form-group {
            display: flex !important;
            flex-direction: column !important;
            gap: 8px !important;
            margin-bottom: 20px !important;
            text-align: left !important;
        }
        .review-form-card .form-group label {
            display: block !important;
            font-size: 0.85rem !important;
            font-weight: 600 !important;
            color: var(--text-secondary) !important;
            margin-bottom: 4px !important;
            text-transform: uppercase !important;
            letter-spacing: 0.5px !important;
        }
        .review-form-card textarea {
            width: 100% !important;
            background: rgba(10, 10, 11, 0.8) !important;
            border: 1px solid var(--border-color) !important;
            border-radius: 10px !important;
            padding: 12px 16px !important;
            color: var(--text-primary) !important;
            font-family: inherit !important;
            font-size: 0.95rem !important;
            transition: all 0.25s ease !important;
            resize: vertical !important;
            min-height: 120px !important;
            outline: none !important;
        }
        .review-form-card textarea:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 15px rgba(245, 166, 35, 0.15) !important;
            background: rgba(10, 10, 11, 0.95) !important;
        }
        .review-form-card button.btn-primary {
            align-self: flex-start !important;
            margin-top: 10px !important;
        }
        .text-muted {
            color: var(--text-muted);
        }
        .course-reviews-summary {
            display: flex;
            align-items: center;
            gap: 20px;
            background: rgba(22, 22, 26, 0.4);
            border: 1px solid #1c1c22;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 24px;
        }
        .average-rating-large {
            font-size: 2.5rem;
            font-weight: 800;
            color: #f5a623;
            line-height: 1;
        }
        .rating-stars-large {
            color: #f5a623;
            font-size: 1.2rem;
            margin: 5px 0;
        }
        .total-reviews-label {
            font-size: 0.85rem;
            color: #a0a0a8;
        }
        .review-item {
            padding: 16px 0;
            border-bottom: 1px solid #1c1c22;
        }
        .review-item:last-child {
            border-bottom: none;
        }
        .review-item-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }
        .reviewer-avatar img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
        }
        .reviewer-name {
            font-size: 0.95rem;
            font-weight: 600;
            margin: 0;
        }
        .review-rating-stars {
            color: #f5a623;
            font-size: 0.8rem;
        }
        .review-date {
            color: #71717a;
            margin-left: 8px;
            font-size: 0.8rem;
        }
        .review-comment {
            font-size: 0.9rem;
            line-height: 1.5;
            color: #d4d4d8;
            margin: 0;
        }
    </style>
}

<!-- Ambient Glows -->
<div class="ambient-glow glow-top-left"></div>
<div class="ambient-glow glow-mid-right"></div>

<!-- COURSE HERO -->
<section class="course-hero">
    <div class="course-hero-inner">
        <div class="course-hero-left">
            <nav class="course-breadcrumb">
                <a href="/">Home</a> / 
                <a href="/courses">Courses</a> / 
                <span>@Model.Title</span>
            </nav>
            <h1 class="course-hero-title">@Model.Title</h1>
            <p class="course-hero-subtitle">@Model.Description</p>
            <div class="course-hero-meta">
                <div class="course-rating">
                    <span class="rating-score">@avgRating.ToString("0.0")</span>
                    <span class="rating-stars">@string.Concat(System.Linq.Enumerable.Repeat("★", roundedRating))@string.Concat(System.Linq.Enumerable.Repeat("☆", 5 - roundedRating))</span>
                    <span class="rating-count">(@reviewsCount reviews)</span>
                </div>
                <span class="course-meta-item">@Model.StudentCount students</span>
                <span class="course-meta-item">@Model.Level</span>
            </div>
            <div class="course-instructor">
                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.InstructorName)&background=f5a623&color=0a0a0b" 
                     alt="@Model.InstructorName" 
                     class="instructor-avatar">
                <div class="instructor-info">
                    <span class="instructor-label">Created by</span>
                    <span class="instructor-name">@Model.InstructorName</span>
                </div>
            </div>
        </div>
        <div class="course-hero-right">
            <div class="course-card-widget">
                <div class="course-widget-image-wrap">
                    <img src="@(Model.ThumbnailUrl ?? "https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=600&h=340&fit=crop&q=80")" 
                         alt="@Model.Title" 
                         class="course-widget-image">
                    @if (Model.IsBestseller)
                    {
                        <span class="course-badge">Bestseller</span>
                    }
                </div>
                <div class="course-widget-body">
                    <h3 class="course-name">@Model.Title</h3>
                    <p class="course-description">@Model.Description</p>
                    <p class="course-instructor">@Model.InstructorName</p>
                    <div class="course-rating">
                        <span class="rating-score">@avgRating.ToString("0.0")</span>
                        <span class="rating-stars">@string.Concat(System.Linq.Enumerable.Repeat("★", roundedRating))@string.Concat(System.Linq.Enumerable.Repeat("☆", 5 - roundedRating))</span>
                        <span class="rating-count">(@reviewsCount)</span>
                    </div>
                    <div class="course-meta">
                        <span class="course-meta-item">@Model.LectureCount lectures</span>
                        <span class="course-meta-item">@hours total hours</span>
                        <span class="course-meta-item">@Model.Level</span>
                    </div>
                    <div class="course-price-and-button">
                        <div class="course-price">
                            <span class="price-current">₹@Model.Price.ToString("N0")</span>
                            <span class="price-original">₹@Model.OriginalPrice.ToString("N0")</span>
                        </div>
                        <button class="course-btn" 
                                data-cart-action="add" 
                                data-course-id="@Model.Id" 
                                data-course-title="@Model.Title" 
                                data-course-price="@Model.Price" 
                                data-course-original-price="@Model.OriginalPrice" 
                                data-course-thumbnail="@(Model.ThumbnailUrl ?? "")" 
                                data-course-level="@Model.Level" 
                                data-course-instructor="@Model.InstructorName">Add to cart</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- COURSE CONTENT -->
<section class="course-content">
    <div class="course-content-inner">
        <div class="course-content-left">
            <!-- What you'll learn -->
            <div class="course-section">
                <h2 class="course-section-title">What you'll learn</h2>
                <div class="course-learn-grid">
                    @if (!string.IsNullOrEmpty(Model.WhatYoullLearn))
                    {
                        var learnItems = Model.WhatYoullLearn.Split(',');
                        foreach (var item in learnItems)
                        {
                            <div class="course-learn-item">
                                <span class="learn-icon">✓</span>
                                <span>@item.Trim()</span>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Course Content -->
            <div class="course-section">
                <h2 class="course-section-title">Course content</h2>
                <div class="course-content-summary">
                    <span class="summary-stats">
                        @(Model.Modules?.Count ?? 0) sections • 
                        @(Model.Modules?.Sum(m => m.Lessons?.Count ?? 0) ?? 0) lectures • 
                        @(Model.DurationMinutes / 60)h @(Model.DurationMinutes % 60)m total length
                    </span>
                    <button class="expand-all-btn">Expand all sections</button>
                </div>
                <div class="course-modules">
                    @if (Model.Modules != null && Model.Modules.Count > 0)
                    {
                        @foreach (var module in Model.Modules)
                        {
                            var lessonCount = module.Lessons?.Count ?? 0;
                            var moduleDuration = $"{module.DurationMinutes / 60}hr {module.DurationMinutes % 60}min";
                            <div class="course-module">
                                <div class="module-header">
                                    <span class="module-toggle">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M7 10L12 15L17 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                    <h3 class="module-title">@module.Title</h3>
                                    <span class="module-meta">@(lessonCount) lectures • @moduleDuration</span>
                                </div>
                                <div class="module-lessons">
                                    @if (module.Lessons != null)
                                    {
                                        @foreach (var lesson in module.Lessons)
                                        {
                                            <div class="module-lesson" 
                                                 data-lesson-id="@lesson.Id" 
                                                 data-video-url="@lesson.VideoUrl" 
                                                 data-preview-video-id="@lesson.PreviewVideoId"
                                                 data-is-preview="@(lesson.IsPreview.ToString().ToLower())">
                                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="lesson-icon">
                                                    <path d="M3 5C3 3.89543 3.89543 3 5 3H15C16.1046 3 17 3.89543 17 5V15C17 16.1046 16.1046 17 15 17H5C3.89543 17 3 16.1046 3 15V5Z" stroke="currentColor" stroke-width="1.5"/>
                                                    <path d="M7.5 7.5L12.5 10L7.5 12.5V7.5Z" fill="currentColor"/>
                                                </svg>
                                                <span class="lesson-title">@lesson.Title</span>
                                                @if (lesson.IsPreview)
                                                {
                                                    <span class="lesson-free-preview">
                                                        <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><polygon points="2,1 9,5 2,9"/></svg>
                                                        Free Preview
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="lesson-lock-badge">
                                                        🔒 <span class="lock-label">Enroll to Watch</span>
                                                    </span>
                                                }
                                                <span class="lesson-duration">@((lesson.DurationSeconds / 60).ToString("00")):@((lesson.DurationSeconds % 60).ToString("00"))</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="no-content">No modules available yet.</p>
                    }
                </div>
            </div>

            <!-- Reviews Section -->
            <div class="course-section" id="reviews-section">
                <h2 class="course-section-title">Student reviews</h2>
                <div class="course-reviews-summary">
                    <div class="reviews-summary-left">
                        <div class="average-rating-large" id="avg-rating-value">@avgRating.ToString("0.0")</div>
                        <div class="rating-stars-large" id="avg-rating-stars">
                            @string.Concat(System.Linq.Enumerable.Repeat("★", roundedRating))@string.Concat(System.Linq.Enumerable.Repeat("☆", 5 - roundedRating))
                        </div>
                        <div class="total-reviews-label" id="total-reviews-label">Course Rating • @reviewsCount reviews</div>
                    </div>
                </div>

                <!-- Review Submission Form -->
                <div class="review-form-card" id="write-review-container" style="display: none;">
                    <h4>Write a Review</h4>
                    <form id="submit-review-form">
                        <div class="form-group">
                            <label>Your Rating</label>
                            <div class="star-rating-picker" id="star-picker">
                                <span class="picker-star" data-value="1">★</span>
                                <span class="picker-star" data-value="2">★</span>
                                <span class="picker-star" data-value="3">★</span>
                                <span class="picker-star" data-value="4">★</span>
                                <span class="picker-star" data-value="5">★</span>
                            </div>
                            <input type="hidden" id="review-rating-input" required value="0">
                        </div>
                        <div class="form-group">
                            <label for="review-comment">Review Comment</label>
                            <textarea id="review-comment" rows="3" placeholder="Tell us about your learning experience..." required maxlength="1000"></textarea>
                        </div>
                        <button type="submit" class="btn-primary" id="btn-submit-review">Submit Review</button>
                    </form>
                </div>

                <div class="review-login-prompt" id="review-status-prompt" style="margin-top: 15px; font-style: italic; color: #a0a0a8;">
                    <!-- Dynamically populated -->
                </div>

                <hr class="divider" style="margin: 28px 0; border-top: 1px solid #222228;">

                <!-- Reviews List -->
                <div class="course-reviews-list" id="reviews-list-container">
                    @if (Model.Reviews != null && Model.Reviews.Count > 0)
                    {
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="review-item">
                                <div class="review-item-header">
                                    <div class="reviewer-avatar">
                                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(review.ReviewerName)&background=f5a623&color=0a0a0b" alt="@review.ReviewerName">
                                    </div>
                                    <div class="reviewer-meta">
                                        <h5 class="reviewer-name">@review.ReviewerName</h5>
                                        <div class="review-rating-stars">
                                            @string.Concat(System.Linq.Enumerable.Repeat("★", review.Rating))@string.Concat(System.Linq.Enumerable.Repeat("☆", 5 - review.Rating))
                                            <span class="review-date">@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                </div>
                                <p class="review-comment">@review.Comment</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="no-reviews text-muted">No reviews yet for this course. Be the first to leave one!</p>
                    }
                </div>
            </div>
        </div>
        
        <div class="course-content-right">
            <!-- Requirements -->
            <div class="course-sidebar-section">
                <h3 class="sidebar-title">Requirements</h3>
                <ul class="requirements-list">
                    @if (!string.IsNullOrEmpty(Model.Requirements))
                    {
                        var reqItems = Model.Requirements.Split(',');
                        foreach (var item in reqItems)
                        {
                            <li>@item.Trim()</li>
                        }
                    }
                </ul>
            </div>

            <!-- Description -->
            <div class="course-sidebar-section">
                <h3 class="sidebar-title">Description</h3>
                <p class="course-description">@Model.Description</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const courseTitle = "@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(Model.Title))";
            const ctaButtons = document.querySelectorAll('.course-btn');

            // ===== PREMIUM DYNAMIC COURSE ENROLLMENT & LESSON PLAYBACK =====
            function checkEnrollment() {
                const enrolledCourses = JSON.parse(localStorage.getItem('enrolledCourses') || '[]');
                const hasSub = localStorage.getItem('hasActiveSubscription') === 'true';
                if (hasSub || enrolledCourses.includes(courseTitle)) {
                    ctaButtons.forEach(btn => {
                        btn.textContent = "Resume Learning";
                        btn.style.background = "#4ade80"; // Green accent for enrolled state
                        btn.style.color = "#0a0a0b";
                        btn.style.boxShadow = "0 8px 30px rgba(74, 222, 128, 0.25)";
                        
                        // Scroll to syllabus on click when enrolled
                        btn.addEventListener('click', function(e) {
                            e.preventDefault();
                            e.stopPropagation();
                            document.querySelector('.course-modules')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        });
                    });
                }
            }

            function setupLessons() {
                const lessons = document.querySelectorAll('.module-lesson');
                const completedLessons = JSON.parse(localStorage.getItem('completedLessons') || '{}');

                const playSvg = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="lesson-icon"><path d="M3 5C3 3.89543 3.89543 3 5 3H15C16.1046 3 17 3.89543 17 5V15C17 16.1046 16.1046 17 15 17H5C3.89543 17 3 16.1046 3 15V5Z" stroke="currentColor" stroke-width="1.5"/><path d="M7.5 7.5L12.5 10L7.5 12.5V7.5Z" fill="currentColor"/></svg>`;
                const checkSvg = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="lesson-icon completed-icon"><path d="M3 5C3 3.89543 3.89543 3 5 3H15C16.1046 3 17 3.89543 17 5V15C17 16.1046 16.1046 17 15 17H5C3.89543 17 3 16.1046 3 15V5Z" stroke="#4ade80" stroke-width="1.5"/><path d="M6.5 10L9 12.5L14 7.5" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

                const enrolledCourses = JSON.parse(localStorage.getItem('enrolledCourses') || '[]');
                const hasSub = localStorage.getItem('hasActiveSubscription') === 'true';
                const userData = JSON.parse(localStorage.getItem('userData') || '{}');
                const isAdmin = userData && userData.role === 'Admin';
                const isEnrolled = hasSub || enrolledCourses.includes(courseTitle) || isAdmin;
                const isLoggedIn = !!localStorage.getItem('userToken');

                lessons.forEach((lesson) => {
                    const titleEl = lesson.querySelector('.lesson-title');
                    if (!titleEl) return;
                    const lessonTitle = titleEl.textContent.trim();
                    const lessonKey = `${courseTitle} - ${lessonTitle}`;
                    const videoUrl = lesson.dataset.videoUrl;
                    const isPreview = lesson.dataset.isPreview === 'true';

                    // If user is logged in, hide the free preview badge
                    const freePreviewBadge = lesson.querySelector('.lesson-free-preview');
                    if (freePreviewBadge) {
                        if (isLoggedIn) {
                            freePreviewBadge.style.display = 'none';
                        } else {
                            freePreviewBadge.style.display = '';
                        }
                    }

                    // ── Apply visual state based on enrollment ──────────────
                    if (isEnrolled) {
                        // Enrolled: all lessons unlocked, hide lock badges
                        lesson.classList.remove('locked');
                        lesson.classList.add('enrolled');
                        lesson.style.cursor = 'pointer';

                        // Mark completed lessons
                        if (completedLessons[lessonKey]) {
                            lesson.classList.add('completed');
                            const oldIcon = lesson.querySelector('.lesson-icon');
                            if (oldIcon) oldIcon.outerHTML = checkSvg;
                        }
                    } else {
                        // Not enrolled: preview lessons clickable, others locked
                        if (isPreview) {
                            lesson.classList.remove('locked');
                            lesson.style.cursor = 'pointer';
                        } else {
                            lesson.classList.add('locked');
                            lesson.style.cursor = 'default';
                        }
                    }

                    // ── Attach click handler (once) ─────────────────────────
                    if (!lesson.dataset.hasListener) {
                        lesson.dataset.hasListener = 'true';
                        lesson.addEventListener('click', function(e) {
                            // Re-check enrollment at click time
                            const latestEnrolled = JSON.parse(localStorage.getItem('enrolledCourses') || '[]');
                            const latestHasSub = localStorage.getItem('hasActiveSubscription') === 'true';
                            const userData = JSON.parse(localStorage.getItem('userData') || '{}');
                            const isAdmin = userData && userData.role === 'Admin';
                            const currentlyEnrolled = latestHasSub || latestEnrolled.includes(courseTitle) || isAdmin;

                            const iconClick = e.target.closest('.lesson-icon');

                            if (iconClick) {
                                // ── Toggle completion (enrolled only) ────────
                                if (currentlyEnrolled) {
                                    const isCompleted = lesson.classList.contains('completed');
                                    if (isCompleted) {
                                        lesson.classList.remove('completed');
                                        const oldIcon = lesson.querySelector('.lesson-icon');
                                        if (oldIcon) oldIcon.outerHTML = playSvg;
                                        delete completedLessons[lessonKey];
                                    } else {
                                        lesson.classList.add('completed');
                                        const oldIcon = lesson.querySelector('.lesson-icon');
                                        if (oldIcon) oldIcon.outerHTML = checkSvg;
                                        completedLessons[lessonKey] = true;
                                    }
                                    localStorage.setItem('completedLessons', JSON.stringify(completedLessons));

                                    const totalLessons = lessons.length;
                                    const completedCount = Array.from(lessons).filter(l => l.classList.contains('completed')).length;
                                    const progress = totalLessons > 0 ? Math.round((completedCount / totalLessons) * 100) : 0;
                                    const courseProgress = JSON.parse(localStorage.getItem('courseProgress') || '{}');
                                    courseProgress[courseTitle] = progress;
                                    localStorage.setItem('courseProgress', JSON.stringify(courseProgress));

                                    showCompletionToast(lessonTitle, !isCompleted);
                                }
                                return;
                            }

                            // ── Play video ────────────────────────────────────
                            if (currentlyEnrolled) {
                                if (videoUrl) {
                                    window.playSecureVideo(videoUrl);
                                } else {
                                    showCompletionToast('No video configured for this lesson yet.', false);
                                }
                            } else if (isPreview) {
                                const previewVidId = lesson.dataset.previewVideoId;
                                if (previewVidId) {
                                    window.playSecureVideo(previewVidId);
                                } else {
                                    showCompletionToast('No preview video configured for this lesson yet.', false);
                                }
                            } else {
                                // ── Locked: shake the lock badge ──────────────
                                const lockBadge = lesson.querySelector('.lesson-lock-badge');
                                if (lockBadge) {
                                    lockBadge.style.animation = 'none';
                                    lockBadge.offsetWidth; // reflow
                                    lockBadge.style.animation = 'lockShake 0.4s ease';
                                    setTimeout(() => { lockBadge.style.animation = ''; }, 450);
                                }
                                // Scroll the enroll button into view as a hint
                                document.querySelector('.course-btn')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            }
                        });
                    }
                });
            }

            function showCompletionToast(lessonTitle, isCompleted) {
                const toast = document.getElementById('toast');
                if (toast) {
                    toast.querySelector('.toast-title').textContent = isCompleted ? 'Lesson Completed!' : 'Lesson Reset';
                    toast.querySelector('.toast-message').textContent = lessonTitle;
                    toast.classList.add('show');
                    setTimeout(() => {
                        toast.classList.remove('show');
                    }, 3000);
                }
            }

            // Run initial check
            checkEnrollment();
            setupLessons();

            // Listen to layout-level enroll event
            window.addEventListener('course-enrolled', function(e) {
                if (e.detail && e.detail.courseName === courseTitle) {
                    checkEnrollment();
                    setupLessons();
                }
            });

            // Listen to authentication state changes
            window.addEventListener('auth-state-changed', function(e) {
                checkEnrollment();
                setupLessons();
            });

            // ===== COURSE REVIEWS INTERACTION =====
            const courseId = @Model.Id;
            const starPicker = document.getElementById('star-picker');
            const ratingInput = document.getElementById('review-rating-input');
            const submitForm = document.getElementById('submit-review-form');
            const reviewComment = document.getElementById('review-comment');
            const writeReviewContainer = document.getElementById('write-review-container');
            const reviewStatusPrompt = document.getElementById('review-status-prompt');
            const reviewsListContainer = document.getElementById('reviews-list-container');
            const avgRatingValue = document.getElementById('avg-rating-value');
            const avgRatingStars = document.getElementById('avg-rating-stars');
            const totalReviewsLabel = document.getElementById('total-reviews-label');

            if (starPicker && ratingInput) {
                const stars = Array.from(starPicker.querySelectorAll('.picker-star'));
                
                stars.forEach((star, index) => {
                    star.addEventListener('mouseenter', () => {
                        stars.forEach((s, idx) => {
                            if (idx <= index) s.classList.add('hover');
                            else s.classList.remove('hover');
                        });
                    });
                    
                    star.addEventListener('mouseleave', () => {
                        stars.forEach(s => s.classList.remove('hover'));
                    });
                    
                    star.addEventListener('click', () => {
                        const val = parseInt(star.dataset.value);
                        ratingInput.value = val;
                        stars.forEach((s, idx) => {
                            if (idx < val) s.classList.add('selected');
                            else s.classList.remove('selected');
                        });
                    });
                });
            }

            async function refreshReviewsUI() {
                try {
                    const response = await fetch(`/api/courses/${courseId}/reviews`);
                    if (!response.ok) return;
                    const reviews = await response.json();
                    
                    if (reviews.length === 0) {
                        reviewsListContainer.innerHTML = '<p class="no-reviews text-muted">No reviews yet for this course. Be the first to leave one!</p>';
                    } else {
                        reviewsListContainer.innerHTML = reviews.map(r => {
                            const dateStr = new Date(r.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
                            const filledStars = '★'.repeat(r.rating);
                            const emptyStars = '☆'.repeat(5 - r.rating);
                            return `
                                <div class="review-item">
                                    <div class="review-item-header">
                                        <div class="reviewer-avatar">
                                            <img src="https://ui-avatars.com/api/?name=${encodeURIComponent(r.reviewerName)}&background=f5a623&color=0a0a0b" alt="${r.reviewerName}">
                                        </div>
                                        <div class="reviewer-meta">
                                            <h5 class="reviewer-name">${r.reviewerName}</h5>
                                            <div class="review-rating-stars">
                                                <span>${filledStars}${emptyStars}</span>
                                                <span class="review-date">${dateStr}</span>
                                            </div>
                                        </div>
                                    </div>
                                    <p class="review-comment">${r.comment}</p>
                                </div>
                            `;
                        }).join('');
                    }

                    if (reviews.length > 0) {
                        const avg = (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1);
                        const roundedAvg = Math.round(parseFloat(avg));
                        const filled = '★'.repeat(roundedAvg);
                        const empty = '☆'.repeat(5 - roundedAvg);
                        
                        if (avgRatingValue) avgRatingValue.textContent = avg;
                        if (avgRatingStars) avgRatingStars.textContent = `${filled}${empty}`;
                        if (totalReviewsLabel) totalReviewsLabel.textContent = `Course Rating • ${reviews.length} reviews`;

                        document.querySelectorAll('.course-rating').forEach(el => {
                            const scoreEl = el.querySelector('.rating-score');
                            const starsEl = el.querySelector('.rating-stars');
                            const countEl = el.querySelector('.rating-count');
                            if (scoreEl) scoreEl.textContent = avg;
                            if (starsEl) starsEl.textContent = `${filled}${empty}`;
                            if (countEl) {
                                countEl.textContent = countEl.textContent.includes('reviews') ? `(${reviews.length} reviews)` : `(${reviews.length})`;
                            }
                        });
                    } else {
                        if (avgRatingValue) avgRatingValue.textContent = '0.0';
                        if (avgRatingStars) avgRatingStars.textContent = '☆☆☆☆☆';
                        if (totalReviewsLabel) totalReviewsLabel.textContent = 'Course Rating • 0 reviews';

                        document.querySelectorAll('.course-rating').forEach(el => {
                            const scoreEl = el.querySelector('.rating-score');
                            const starsEl = el.querySelector('.rating-stars');
                            const countEl = el.querySelector('.rating-count');
                            if (scoreEl) scoreEl.textContent = '0.0';
                            if (starsEl) starsEl.textContent = '☆☆☆☆☆';
                            if (countEl) {
                                countEl.textContent = countEl.textContent.includes('reviews') ? '(0 reviews)' : '(0)';
                            }
                        });
                    }
                } catch (err) {
                    console.error('Error refreshing reviews:', err);
                }
            }

            async function checkReviewEligibility() {
                const token = localStorage.getItem('userToken');
                if (!token) {
                    if (reviewStatusPrompt) {
                        reviewStatusPrompt.textContent = "Please log in to write a review.";
                        reviewStatusPrompt.style.display = "block";
                    }
                    if (writeReviewContainer) writeReviewContainer.style.display = "none";
                    return;
                }

                try {
                    const response = await fetch(`/api/courses/${courseId}/reviews/can-review`, {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    
                    if (!response.ok) {
                        if (reviewStatusPrompt) {
                            reviewStatusPrompt.textContent = "Please enroll in this course to leave a review.";
                            reviewStatusPrompt.style.display = "block";
                        }
                        if (writeReviewContainer) writeReviewContainer.style.display = "none";
                        return;
                    }
                    
                    const data = await response.json();
                    if (data.canReview) {
                        if (reviewStatusPrompt) reviewStatusPrompt.style.display = "none";
                        if (writeReviewContainer) writeReviewContainer.style.display = "block";
                        
                        const reviewsResp = await fetch(`/api/courses/${courseId}/reviews`);
                        if (reviewsResp.ok) {
                            const reviews = await reviewsResp.json();
                            const userData = JSON.parse(localStorage.getItem('userData') || '{}');
                            const myReview = reviews.find(r => r.userId === userData.id || r.reviewerName === userData.fullName || r.reviewerName === userData.FullName);
                            if (myReview) {
                                ratingInput.value = myReview.rating;
                                if (reviewComment) reviewComment.value = myReview.comment;
                                const stars = Array.from(starPicker.querySelectorAll('.picker-star'));
                                stars.forEach((s, idx) => {
                                    if (idx < myReview.rating) s.classList.add('selected');
                                    else s.classList.remove('selected');
                                });
                                const submitBtn = document.getElementById('btn-submit-review');
                                if (submitBtn) submitBtn.textContent = "Update Review";
                                const cardTitle = writeReviewContainer.querySelector('h4');
                                if (cardTitle) cardTitle.textContent = "Edit Your Review";
                            }
                        }
                    } else {
                        if (reviewStatusPrompt) {
                            reviewStatusPrompt.textContent = "Please enroll in this course or activate a subscription to leave a review.";
                            reviewStatusPrompt.style.display = "block";
                        }
                        if (writeReviewContainer) writeReviewContainer.style.display = "none";
                    }
                } catch (err) {
                    console.error('Error checking review eligibility:', err);
                }
            }

            if (submitForm) {
                submitForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const token = localStorage.getItem('userToken');
                    if (!token) return;

                    const rating = parseInt(ratingInput.value);
                    if (rating < 1 || rating > 5) {
                        alert("Please select a rating between 1 and 5 stars.");
                        return;
                    }

                    const comment = reviewComment.value.trim();
                    if (!comment) return;

                    const submitBtn = document.getElementById('btn-submit-review');
                    if (submitBtn) submitBtn.disabled = true;

                    try {
                        const response = await fetch(`/api/courses/${courseId}/reviews`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Authorization': `Bearer ${token}`
                            },
                            body: JSON.stringify({ rating, comment })
                        });

                        if (response.ok) {
                            const toast = document.getElementById('toast');
                            if (toast) {
                                toast.querySelector('.toast-title').textContent = 'Success';
                                toast.querySelector('.toast-message').textContent = 'Your review has been saved!';
                                toast.classList.add('show');
                                setTimeout(() => toast.classList.remove('show'), 3000);
                            }
                            
                            await refreshReviewsUI();
                            await checkReviewEligibility();
                        } else {
                            const err = await response.json();
                            alert(err.message || "Failed to submit review.");
                        }
                    } catch (err) {
                        console.error('Error submitting review:', err);
                        alert("An error occurred. Please try again.");
                    } finally {
                        if (submitBtn) submitBtn.disabled = false;
                    }
                });
            }

            checkReviewEligibility();
            window.addEventListener('auth-state-changed', () => {
                checkReviewEligibility();
            });
            window.addEventListener('course-enrolled', () => {
                checkReviewEligibility();
            });
        });
    </script>
}
