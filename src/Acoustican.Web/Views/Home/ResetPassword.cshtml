@{
    Layout = null;
    var token = ViewData["Token"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>Reset Password - Acoustican Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <style>
        :root {
            --primary: #f5a623;
            --dark: #0a0a0b;
            --darker: #16161a;
            --light-text: #ffffff;
            --muted-text: #a0a0a8;
        }

        * {
            color-scheme: dark;
        }

        body {
            background: var(--dark);
            color: var(--light-text);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        .card {
            background: var(--darker);
            border: 1px solid #222228;
            color: var(--light-text);
        }

        .btn-primary {
            background: var(--primary);
            border: none;
            color: var(--dark);
            font-weight: 600;
        }

        .btn-primary:hover {
            background: #e0951a;
            color: var(--dark);
        }

        .form-control {
            background: var(--darker);
            color: var(--light-text);
            border: 1px solid #222228;
        }

        .form-control:focus {
            background: var(--darker);
            color: var(--light-text);
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(245, 166, 35, 0.25);
        }

        .text-center a {
            color: var(--primary);
        }

        .text-center a:hover {
            color: #e0951a;
        }

        .password-strength {
            height: 4px;
            background: #222228;
            border-radius: 2px;
            margin-top: 8px;
        }

        .password-strength-bar {
            height: 100%;
            border-radius: 2px;
            transition: width 0.3s ease;
        }

        .strength-weak {
            width: 33%;
            background: #dc3545;
        }

        .strength-fair {
            width: 66%;
            background: #ffc107;
        }

        .strength-strong {
            width: 100%;
            background: #28a745;
        }

        .strength-text {
            font-size: 0.75rem;
            margin-top: 4px;
        }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="card" style="width: 100%; max-width: 450px;">
            <div class="card-body p-5">
                <h2 class="text-center mb-2">Reset Password</h2>
                <p class="text-center text-muted mb-4" style="font-size: 0.95rem;">
                    Enter your new password below.
                </p>

                <form id="resetPasswordForm">
                    <div class="mb-4">
                        <label class="form-label">Reset Token</label>
                        <input type="text" class="form-control" id="resetToken" placeholder="Paste reset token" value="@token" required>
                        <small class="text-muted d-block mt-2">The token was provided in the forgot password email</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">New Password</label>
                        <input type="password" class="form-control" id="newPassword" placeholder="Enter new password" required>
                        <div class="password-strength">
                            <div class="password-strength-bar" id="strengthBar"></div>
                        </div>
                        <div class="strength-text" id="strengthText"></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" id="confirmPassword" placeholder="Confirm new password" required>
                        <small id="passwordMatch" class="text-danger d-none d-block mt-2">Passwords do not match</small>
                        <small id="passwordMatchOk" class="text-success d-none d-block mt-2">Passwords match</small>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3">
                        <i class="fas fa-key"></i> Reset Password
                    </button>
                </form>

                <div id="successMessage" class="alert alert-success d-none" role="alert">
                    <i class="fas fa-check-circle"></i> 
                    <span id="successText">Password has been reset successfully!</span>
                </div>

                <div id="errorMessage" class="alert alert-danger d-none" role="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    <span id="errorText"></span>
                </div>

                <div class="text-center mt-4">
                    <a href="/admin" class="btn btn-link text-decoration-none">
                        <i class="fas fa-sign-in-alt"></i> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        const API_URL = '/api';

        // Password strength indicator
        document.getElementById('newPassword').addEventListener('input', (e) => {
            const password = e.target.value;
            const strength = calculatePasswordStrength(password);
            updatePasswordStrength(strength);
            checkPasswordMatch();
        });

        document.getElementById('confirmPassword').addEventListener('input', checkPasswordMatch);

        function calculatePasswordStrength(password) {
            let strength = 0;
            if (password.length >= 8) strength++;
            if (password.length >= 12) strength++;
            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
            if (/\d/.test(password)) strength++;
            if (/[^a-zA-Z0-9]/.test(password)) strength++;
            return Math.min(strength, 3);
        }

        function updatePasswordStrength(strength) {
            const bar = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');
            
            bar.className = 'password-strength-bar';
            
            if (strength === 0) {
                bar.classList.add('strength-weak');
                text.textContent = 'Weak password';
                text.className = 'strength-text text-danger';
            } else if (strength === 1 || strength === 2) {
                bar.classList.add('strength-fair');
                text.textContent = 'Fair password';
                text.className = 'strength-text text-warning';
            } else {
                bar.classList.add('strength-strong');
                text.textContent = 'Strong password';
                text.className = 'strength-text text-success';
            }
        }

        function checkPasswordMatch() {
            const password = document.getElementById('newPassword').value;
            const confirm = document.getElementById('confirmPassword').value;
            const matchError = document.getElementById('passwordMatch');
            const matchOk = document.getElementById('passwordMatchOk');

            if (confirm.length === 0) {
                matchError.classList.add('d-none');
                matchOk.classList.add('d-none');
            } else if (password === confirm) {
                matchError.classList.add('d-none');
                matchOk.classList.remove('d-none');
            } else {
                matchError.classList.remove('d-none');
                matchOk.classList.add('d-none');
            }
        }

        document.getElementById('resetPasswordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const token = document.getElementById('resetToken').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (newPassword !== confirmPassword) {
                document.getElementById('errorMessage').classList.remove('d-none');
                document.getElementById('errorText').textContent = 'Passwords do not match';
                return;
            }

            const submitBtn = e.target.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;

            try {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Resetting...';

                const response = await fetch(API_URL + '/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token, newPassword })
                }).then(r => r.json());

                if (response.success) {
                    document.getElementById('errorMessage').classList.add('d-none');
                    document.getElementById('successMessage').classList.remove('d-none');
                    document.getElementById('resetPasswordForm').style.display = 'none';
                    
                    setTimeout(() => {
                        window.location.href = '/admin';
                    }, 2000);
                } else {
                    document.getElementById('errorMessage').classList.remove('d-none');
                    document.getElementById('errorText').textContent = response.message || 'An error occurred';
                }
            } catch (err) {
                console.error('Error:', err);
                document.getElementById('errorMessage').classList.remove('d-none');
                document.getElementById('errorText').textContent = 'An error occurred. Please try again.';
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });
    </script>
</body>
</html>
