@{
    ViewData["Title"] = "Shopping Cart";
}

@section Styles {
    <link rel="stylesheet" href="/cart.css?v=@DateTime.UtcNow.Ticks">
}

<!-- PAGE HERO -->
<section class="cart-hero">
    <div class="cart-hero-inner">
        <h1 class="cart-hero-title">Your <span>Cart</span></h1>
        <p class="cart-hero-desc">Review your selected courses and take the next step in your guitar mastery journey.</p>
    </div>
</section>

<!-- MAIN CART CONTENT -->
<div class="cart-container" id="cartContainer">
    <!-- Loading State -->
    <div id="cartLoading" style="text-align: center; padding: 60px 0;">
        <div class="drawer-empty-icon" style="animation: pulse 1.5s infinite; font-size: 3rem;">🛒</div>
        <p style="color: var(--text-muted); margin-top: 16px;">Loading your cart items...</p>
    </div>

    <!-- Empty State (hidden by default) -->
    <div id="cartEmpty" class="cart-empty-state" style="display: none;">
        <span class="empty-icon">🎸</span>
        <h2>Your Cart is Empty</h2>
        <p>You haven't added any courses to your cart yet. Explore our professional curriculum and find your perfect path.</p>
        <a href="/courses" class="btn-shop-courses">
            Browse Courses
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
        </a>
    </div>

    <!-- Active Cart Layout (hidden by default) -->
    <div id="cartActive" class="cart-layout" style="display: none;">
        <!-- Left: Cart Items -->
        <div class="cart-items-section" id="cartItemsList">
            <!-- Dynamic Cart Items here -->
        </div>

        <!-- Right: Checkout Summary -->
        <aside class="cart-summary-card">
            <h3 class="summary-title">Order Summary</h3>
            
            <div class="summary-row">
                <span>Selected Courses</span>
                <span id="summaryCount">0 items</span>
            </div>
            <div class="summary-row">
                <span>Original Price</span>
                <span id="summaryOriginalTotal">₹0</span>
            </div>
            <div class="summary-row discount">
                <span>Discount Saving</span>
                <span id="summaryDiscount">₹0</span>
            </div>
            
            <div class="promo-code-wrap">
                <input type="text" class="promo-input" placeholder="Promo code..." aria-label="Promo code">
                <button type="button" class="btn-promo-apply">Apply</button>
            </div>

            <div class="summary-row total">
                <span>Total Amount</span>
                <strong id="summaryTotal">₹0</strong>
            </div>

            <button type="button" class="btn-checkout-submit" id="btnCheckout">
                Proceed to Checkout
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>

            <p class="summary-notice">Instant lifetime access • HD video streaming • Downloadable attachments • 30-day money-back guarantee</p>
        </aside>
    </div>

    <!-- Success Confirmation State (hidden by default) -->
    <div id="cartSuccess" class="checkout-success-state" style="display: none;">
        <span class="success-icon">✓</span>
        <h2>Enrollment Confirmed!</h2>
        <p>Congratulations! You have successfully registered for your courses. Start learning right away.</p>
        
        <div class="order-details-box">
            <div class="order-detail-row">
                <span>Order Reference</span>
                <strong id="successOrderId">#ORD-0000</strong>
            </div>
            <div class="order-detail-row">
                <span>Amount Paid</span>
                <strong id="successOrderTotal">₹0</strong>
            </div>
            <div class="order-detail-row">
                <span>Access Status</span>
                <strong style="color: var(--success);">Instant Lifetime Access</strong>
            </div>
        </div>

        <div class="success-actions">
            <a href="/orders" class="btn-action-primary">View My Orders</a>
            <a href="/courses" class="btn-action-secondary">Explore More</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loadingEl = document.getElementById('cartLoading');
            const emptyEl = document.getElementById('cartEmpty');
            const activeEl = document.getElementById('cartActive');
            const successEl = document.getElementById('cartSuccess');
            const itemsListEl = document.getElementById('cartItemsList');
            
            const summaryCount = document.getElementById('summaryCount');
            const summaryOriginalTotal = document.getElementById('summaryOriginalTotal');
            const summaryDiscount = document.getElementById('summaryDiscount');
            const summaryTotal = document.getElementById('summaryTotal');
            const btnCheckout = document.getElementById('btnCheckout');

            // Success View Elements
            const successOrderId = document.getElementById('successOrderId');
            const successOrderTotal = document.getElementById('successOrderTotal');

            let cartItems = [];

            // Expose renderCartPage so GVCart can invoke it on removal
            window.renderCartPage = async function() {
                loadingEl.style.display = 'block';
                emptyEl.style.display = 'none';
                activeEl.style.display = 'none';
                successEl.style.display = 'none';

                if (window.GVCart.isLoggedIn()) {
                    try {
                        const res = await fetch('/api/cart', { headers: window.GVCart.authHeaders() });
                        if (res.ok) {
                            const data = await res.json();
                            // Map DB keys to common schema
                            cartItems = (data.items || []).map(i => ({
                                courseId: i.courseId,
                                title: i.courseTitle,
                                price: i.coursePrice,
                                originalPrice: i.courseOriginalPrice,
                                thumbnailUrl: i.courseThumbnailUrl,
                                level: i.courseLevel,
                                instructor: i.instructorName
                            }));
                        } else {
                            cartItems = [];
                        }
                    } catch {
                        cartItems = [];
                    }
                } else {
                    const guest = window.GVCart.getGuestCart();
                    cartItems = guest.map(g => ({
                        courseId: g.courseId,
                        title: g.courseTitle,
                        price: g.coursePrice,
                        originalPrice: g.courseOriginalPrice,
                        thumbnailUrl: g.courseThumbnail,
                        level: g.courseLevel,
                        instructor: g.instructorName
                    }));
                }

                loadingEl.style.display = 'none';

                if (cartItems.length === 0) {
                    emptyEl.style.display = 'block';
                    return;
                }

                activeEl.style.display = 'grid';
                
                // Render List
                itemsListEl.innerHTML = cartItems.map(item => {
                    const saved = item.originalPrice - item.price;
                    return `
                        <div class="cart-item-card" data-course-id="${item.courseId}">
                            <div class="cart-item-thumb-wrap">
                                <img src="${item.thumbnailUrl || 'https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=400&h=250&fit=crop&q=80'}" alt="${item.title}" class="cart-item-thumb">
                            </div>
                            <div class="cart-item-details">
                                <div>
                                    <div class="cart-item-header">
                                        <h3 class="cart-item-title">${item.title}</h3>
                                        <button class="btn-remove-item" onclick="window.GVCart.removeFromCart(${item.courseId})">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                            Remove
                                        </button>
                                    </div>
                                    <p class="cart-item-instructor">By ${item.instructor || 'Academy Master'}</p>
                                    <div class="cart-item-meta">
                                        <span class="cart-meta-tag level">${item.level || 'All Levels'}</span>
                                        ${saved > 0 ? `<span class="cart-meta-tag" style="color:var(--success);">₹${saved.toLocaleString('en-IN')} Saved</span>` : ''}
                                    </div>
                                </div>
                                <div class="cart-item-footer">
                                    <div class="cart-item-price">
                                        <span class="price-now">₹${item.price.toLocaleString('en-IN')}</span>
                                        ${item.originalPrice > item.price ? `<span class="price-was">₹${item.originalPrice.toLocaleString('en-IN')}</span>` : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');

                // Render Summary
                const total = cartItems.reduce((sum, i) => sum + i.price, 0);
                const originalTotal = cartItems.reduce((sum, i) => sum + i.originalPrice, 0);
                const discount = originalTotal - total;

                summaryCount.textContent = `${cartItems.length} course${cartItems.length > 1 ? 's' : ''}`;
                summaryOriginalTotal.textContent = `₹${originalTotal.toLocaleString('en-IN')}`;
                summaryDiscount.textContent = `₹${discount.toLocaleString('en-IN')}`;
                summaryTotal.textContent = `₹${total.toLocaleString('en-IN')}`;
            };

            // Checkout action
            btnCheckout.addEventListener('click', async function() {
                if (!window.GVCart.isLoggedIn()) {
                    // Force login modal
                    window.openAuthModal('login');
                    return;
                }

                btnCheckout.disabled = true;
                btnCheckout.innerHTML = `<span style="animation: pulse 1s infinite;">Processing checkout...</span>`;

                try {
                    const res = await fetch('/api/orders/checkout', {
                        method: 'POST',
                        headers: window.GVCart.authHeaders()
                    });
                    const data = await res.json();
                    
                    if (res.ok && data.success) {
                        const order = data.order;
                        const orderId = order.id;
                        const totalAmount = order.totalAmount;
                        const items = order.items;

                        const verifyPayment = async (razorpayOrderId, razorpayPaymentId, razorpaySignature) => {
                            try {
                                const verifyRes = await fetch('/api/orders/verify', {
                                    method: 'POST',
                                    headers: window.GVCart.authHeaders(),
                                    body: JSON.stringify({
                                        razorpayOrderId,
                                        razorpayPaymentId,
                                        razorpaySignature
                                    })
                                });
                                const verifyData = await verifyRes.json();

                                if (verifyRes.ok && verifyData.success) {
                                    // Clear cart locally if any leftover
                                    window.GVCart.clearGuestCart();
                                    await window.GVCart.refreshBadge();
                                    
                                    // Show success view
                                    successOrderId.textContent = `#GVA-ORD-${orderId}`;
                                    successOrderTotal.textContent = `₹${totalAmount.toLocaleString('en-IN')}`;
                                    
                                    activeEl.style.display = 'none';
                                    successEl.style.display = 'block';

                                    // Save purchased course titles to local storage for the CourseDetail "Resume Learning" UI check
                                    const enrolledCourses = JSON.parse(localStorage.getItem('enrolledCourses') || '[]');
                                    items.forEach(item => {
                                        if (!enrolledCourses.includes(item.courseTitle)) {
                                            enrolledCourses.push(item.courseTitle);
                                        }
                                    });
                                    localStorage.setItem('enrolledCourses', JSON.stringify(enrolledCourses));
                                } else {
                                    alert(verifyData.message || 'Payment verification failed. Please try again.');
                                    resetCheckoutBtn();
                                }
                            } catch {
                                alert('An error occurred during payment verification. Please check your connection.');
                                resetCheckoutBtn();
                            }
                        };

                        const resetCheckoutBtn = () => {
                            btnCheckout.disabled = false;
                            btnCheckout.innerHTML = `Proceed to Checkout <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;
                        };

                        // Check if we are running in Mock Mode
                        if (order.razorpayOrderId && order.razorpayOrderId.startsWith("order_mock_")) {
                            showMockPaymentModal(order, 
                                (response) => {
                                    verifyPayment(response.razorpay_order_id, response.razorpay_payment_id, response.razorpay_signature);
                                }, 
                                (errorMsg) => {
                                    alert(errorMsg);
                                    resetCheckoutBtn();
                                }
                            );
                        } else {
                            // Real Razorpay Flow
                            const options = {
                                "key": order.razorpayKey,
                                "amount": Math.round(order.totalAmount * 100), // in paise
                                "currency": "INR",
                                "name": "Acoustican",
                                "description": "Course Enrollment Purchase",
                                "order_id": order.razorpayOrderId,
                                "handler": function (response) {
                                    verifyPayment(response.razorpay_order_id, response.razorpay_payment_id, response.razorpay_signature);
                                },
                                "prefill": {
                                    "name": "",
                                    "email": ""
                                },
                                "theme": {
                                    "color": "#f5a623"
                                },
                                "modal": {
                                    "ondismiss": function() {
                                        resetCheckoutBtn();
                                    }
                                }
                            };

                            // Retrieve prefill info if possible
                            try {
                                const userData = JSON.parse(localStorage.getItem('userData'));
                                if (userData) {
                                    options.prefill.name = userData.name || userData.username || "";
                                    options.prefill.email = userData.email || "";
                                }
                            } catch (_) {}

                            const rzp = new Razorpay(options);
                            rzp.on('payment.failed', function (response) {
                                alert("Payment failed: " + response.error.description);
                                resetCheckoutBtn();
                            });
                            rzp.open();
                        }
                    } else {
                        alert(data.message || 'Checkout failed. Please try again.');
                        btnCheckout.disabled = false;
                        btnCheckout.innerHTML = `Proceed to Checkout <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;
                    }
                } catch (e) {
                    console.error(e);
                    alert('An error occurred during checkout. Please check your connection.');
                    btnCheckout.disabled = false;
                    btnCheckout.innerHTML = `Proceed to Checkout <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;
                }
            });

            function showMockPaymentModal(order, onConfirm, onCancel) {
                const existing = document.getElementById('mockPaymentOverlay');
                if (existing) existing.remove();

                const overlay = document.createElement('div');
                overlay.id = 'mockPaymentOverlay';
                overlay.style.position = 'fixed';
                overlay.style.top = '0';
                overlay.style.left = '0';
                overlay.style.width = '100%';
                overlay.style.height = '100%';
                overlay.style.backgroundColor = 'rgba(10, 10, 12, 0.85)';
                overlay.style.backdropFilter = 'blur(12px)';
                overlay.style.display = 'flex';
                overlay.style.alignItems = 'center';
                overlay.style.justifyContent = 'center';
                overlay.style.zIndex = '99999';
                overlay.style.fontFamily = "'Inter', sans-serif";

                const card = document.createElement('div');
                card.style.background = 'linear-gradient(135deg, #1e1e24, #121216)';
                card.style.border = '1px solid rgba(255, 255, 255, 0.08)';
                card.style.borderRadius = '20px';
                card.style.padding = '32px';
                card.style.width = '100%';
                card.style.maxWidth = '420px';
                card.style.color = '#ffffff';
                card.style.boxShadow = '0 20px 40px rgba(0, 0, 0, 0.5)';
                card.style.textAlign = 'center';

                card.innerHTML = `
                    <div style="font-size: 3rem; margin-bottom: 16px;">🎸</div>
                    <h3 style="margin: 0 0 8px; font-size: 1.5rem; font-weight: 700; background: linear-gradient(90deg, #f5a623, #f8e71c); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        Mock Payment Gateway
                    </h3>
                    <div style="display: inline-block; padding: 4px 10px; font-size: 0.75rem; background: rgba(245, 166, 35, 0.15); border: 1px solid rgba(245, 166, 35, 0.3); border-radius: 20px; color: #f5a623; margin-bottom: 24px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                        Test Mode (No Keys)
                    </div>
                    
                    <div style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 12px; padding: 16px; text-align: left; margin-bottom: 24px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <span style="color: rgba(255, 255, 255, 0.5); font-size: 0.9rem;">Order Reference</span>
                            <span style="font-weight: 600; font-size: 0.9rem;">#GVA-ORD-${order.id}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span style="color: rgba(255, 255, 255, 0.5); font-size: 0.9rem;">Amount Due</span>
                            <span style="font-weight: 700; color: #4ade80; font-size: 1.1rem;">₹${order.totalAmount.toLocaleString('en-IN')}</span>
                        </div>
                    </div>

                    <p style="color: rgba(255, 255, 255, 0.6); font-size: 0.9rem; margin-bottom: 24px; line-height: 1.5;">
                        Simulate a transaction outcome to verify backend order validation and user enrollment.
                    </p>

                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <button id="btnMockSuccess" style="background: #22c55e; border: none; border-radius: 10px; padding: 12px; color: #fff; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.2s;">
                            Simulate Successful Payment
                        </button>
                        <button id="btnMockFailure" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 10px; padding: 12px; color: #ef4444; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.2s;">
                            Simulate Failed Payment
                        </button>
                        <button id="btnMockCancel" style="background: transparent; border: none; padding: 8px; color: rgba(255, 255, 255, 0.4); font-size: 0.85rem; cursor: pointer; text-decoration: underline;">
                            Cancel Checkout
                        </button>
                    </div>
                `;

                overlay.appendChild(card);
                document.body.appendChild(overlay);

                document.getElementById('btnMockSuccess').onclick = () => {
                    overlay.remove();
                    onConfirm({
                        razorpay_order_id: order.razorpayOrderId,
                        razorpay_payment_id: "pay_mock_" + Math.random().toString(36).substring(2, 11),
                        razorpay_signature: "sig_mock_" + Math.random().toString(36).substring(2, 11)
                    });
                };

                document.getElementById('btnMockFailure').onclick = () => {
                    overlay.remove();
                    onCancel("Payment simulation failed.");
                };

                document.getElementById('btnMockCancel').onclick = () => {
                    overlay.remove();
                    onCancel("Checkout cancelled by user.");
                };
            }

            // Run initial load
            window.renderCartPage();

        });
    </script>
}
