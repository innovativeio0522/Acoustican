@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title>Forgot Password - Acoustican Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <style>
        :root {
            --primary: #f5a623;
            --dark: #0a0a0b;
            --darker: #16161a;
            --light-text: #ffffff;
            --muted-text: #a0a0a8;
        }

        * {
            color-scheme: dark;
        }

        body {
            background: var(--dark);
            color: var(--light-text);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        .card {
            background: var(--darker);
            border: 1px solid #222228;
            color: var(--light-text);
        }

        .btn-primary {
            background: var(--primary);
            border: none;
            color: var(--dark);
            font-weight: 600;
        }

        .btn-primary:hover {
            background: #e0951a;
            color: var(--dark);
        }

        .form-control {
            background: var(--darker);
            color: var(--light-text);
            border: 1px solid #222228;
        }

        .form-control:focus {
            background: var(--darker);
            color: var(--light-text);
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(245, 166, 35, 0.25);
        }

        .text-center a {
            color: var(--primary);
        }

        .text-center a:hover {
            color: #e0951a;
        }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="card" style="width: 100%; max-width: 450px;">
            <div class="card-body p-5">
                <h2 class="text-center mb-2">Forgot Password?</h2>
                <p class="text-center text-muted mb-4" style="font-size: 0.95rem;">
                    Enter your email address and we'll send you a link to reset your password.
                </p>

                <form id="forgotPasswordForm">
                    <div class="mb-4">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" id="forgotEmail" placeholder="admin@example.com" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mb-3">
                        <i class="fas fa-envelope"></i> Send Reset Link
                    </button>
                </form>

                <div id="successMessage" class="alert alert-success d-none" role="alert">
                    <i class="fas fa-check-circle"></i> 
                    <span id="successText">If an account exists with this email, you will receive password reset instructions.</span>
                </div>

                <div id="errorMessage" class="alert alert-danger d-none" role="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    <span id="errorText"></span>
                </div>

                <div class="text-center mt-4">
                    <p class="text-muted mb-3">Remember your password?</p>
                    <a href="/admin" class="btn btn-link text-decoration-none">
                        <i class="fas fa-sign-in-alt"></i> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        const API_URL = '/api';

        document.getElementById('forgotPasswordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('forgotEmail').value;
            const submitBtn = e.target.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;

            try {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';

                const response = await fetch(API_URL + '/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                }).then(r => r.json());

                document.getElementById('errorMessage').classList.add('d-none');
                document.getElementById('successMessage').classList.remove('d-none');
                document.getElementById('forgotPasswordForm').style.display = 'none';

                if (response.success) {
                    document.getElementById('successText').innerHTML = 
                        `<strong>Password reset email sent!</strong><br><small class="text-muted">Check your email for a link to reset your password. The link will expire in 24 hours.</small>`;
                } else {
                    document.getElementById('successText').innerHTML = 
                        `<strong>If an account exists with this email, a password reset link will be sent.</strong>`;
                }
            } catch (err) {
                console.error('Error:', err);
                document.getElementById('errorMessage').classList.remove('d-none');
                document.getElementById('errorText').textContent = 'An error occurred. Please try again.';
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });
    </script>
</body>
</html>
